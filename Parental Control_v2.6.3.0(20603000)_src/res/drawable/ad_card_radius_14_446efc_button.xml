<?xml version="1.0" encoding="utf-8"?>
<selector
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_pressed="true">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/kid_btn_blue_clicked" />
            <padding
                android:left="12.0dip"
                android:top="5.0dip"
                android:right="12.0dip"
                android:bottom="5.0dip" />
            <corners
                android:radius="14.0dip" />
        </shape>
    </item>
    <item
        android:state_enabled="false">
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/kid_btn_blue_disable" />
            <padding
                android:left="12.0dip"
                android:top="5.0dip"
                android:right="12.0dip"
                android:bottom="5.0dip" />
            <corners
                android:radius="14.0dip" />
        </shape>
    </item>
    <item>
        <shape
            android:shape="rectangle">
            <solid
                android:color="@color/kid_bind_text_blue" />
            <corners
                android:radius="8.0dip" />
            <padding
                android:left="12.0dip"
                android:top="5.0dip"
                android:right="12.0dip"
                android:bottom="5.0dip" />
            <corners
                android:radius="14.0dip" />
        </shape>
    </item>
</selector>