<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="start|center"
        android:height="6.0dip"
        android:width="6.0dip"
        android:start="1.0dip">
        <shape
            android:shape="oval">
            <solid
                android:color="@android:color/white" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:height="8.0dip"
        android:width="8.0dip">
        <shape
            android:shape="oval">
            <solid
                android:color="@android:color/white" />
        </shape>
    </item>
    <item
        android:gravity="end|center"
        android:height="6.0dip"
        android:width="6.0dip"
        android:end="1.0dip">
        <shape
            android:shape="oval">
            <solid
                android:color="@android:color/white" />
        </shape>
    </item>
    <item
        android:height="25.0dip"
        android:width="34.0dip">
        <shape
            android:shape="rectangle" />
    </item>
</layer-list>