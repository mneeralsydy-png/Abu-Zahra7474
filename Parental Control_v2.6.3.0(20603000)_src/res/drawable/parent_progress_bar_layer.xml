<?xml version="1.0" encoding="utf-8"?>
<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/background">
        <shape>
            <gradient
                android:startColor="#fff4f4f4"
                android:endColor="#fff4f4f4"
                android:angle="270.0"
                android:centerY="0.75"
                android:centerColor="#fff4f4f4" />
        </shape>
    </item>
    <item
        android:id="@android:id/secondaryProgress">
        <scale
            android:scaleWidth="100%">
            <shape>
                <gradient
                    android:startColor="#ff42c662"
                    android:endColor="#ff42c662"
                    android:angle="270.0"
                    android:centerY="0.75" />
            </shape>
        </scale>
    </item>
    <item
        android:id="@android:id/progress">
        <scale
            android:scaleWidth="100%">
            <shape>
                <gradient
                    android:startColor="#ff42c662"
                    android:endColor="#ff42c662"
                    android:angle="270.0"
                    android:centerY="0.75" />
            </shape>
        </scale>
    </item>
</layer-list>