<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/white_ffffff"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0.0dip"
        android:layout_height="fill_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <View
            android:background="@drawable/bg_parent_permission_top"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            app:layout_constraintBottom_toBottomOf="@id/ivChecking"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/pic_clouds_left"
            app:layout_constraintBottom_toBottomOf="@id/ivChecking"
            app:layout_constraintStart_toStartOf="parent" />
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/pic_clouds_right"
            app:layout_constraintBottom_toBottomOf="@id/ivChecking"
            app:layout_constraintEnd_toEndOf="parent" />
        <ImageView
            android:id="@id/ivChecking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48.0dip"
            android:src="@drawable/pic_permiss_normal_pad"
            app:layout_constrainedHeight="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="22.0sp"
            android:textColor="@color/black_282930"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvDeviceName"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="30.0dip"
            android:layout_marginRight="20.0dip"
            android:maxLines="1"
            android:layout_marginHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivChecking"
            app:layout_constraintWidth_max="@dimen/tablet_max_width" />
        <TextView
            android:textColor="@color/white_ffffff"
            android:gravity="center"
            android:id="@id/tvSuccess"
            android:background="@drawable/permission_check_success_text_bg"
            android:paddingLeft="5.0dip"
            android:paddingTop="1.0dip"
            android:paddingRight="5.0dip"
            android:paddingBottom="1.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.0dip"
            android:text="@string/Parent_Permission_Normal_Title"
            android:paddingHorizontal="5.0dip"
            android:paddingVertical="1.0dip"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDeviceName" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/gray_464f60"
            android:gravity="center"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="25.0dip"
            android:layout_marginRight="20.0dip"
            android:text="@string/Parent_Permission_Normal_Text"
            android:layout_marginHorizontal="20.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSuccess"
            app:layout_constraintWidth_max="@dimen/tablet_max_width" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>