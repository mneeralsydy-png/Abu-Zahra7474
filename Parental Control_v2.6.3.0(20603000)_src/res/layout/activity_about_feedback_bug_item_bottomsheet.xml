<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/bottom_sheet_dialog_bg"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:maxWidth="@dimen/tablet_max_width"
    android:paddingStart="20.0dip"
    android:paddingEnd="20.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.0dip"
        android:src="@drawable/bottom_sheet_mark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@id/tvFeedBackItemTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34.0dip"
        android:text="@string/ad_setting_about_feedback_type"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/bottom_sheet_title_style" />
    <RadioGroup
        android:id="@id/optionGroup"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFeedBackItemTitle">
        <com.sand.airdroidkid.common.ui.custom.BottomSheetDialogOptionRadioButton
            android:id="@id/btFeedBackItemBugReport"
            android:layout_width="fill_parent"
            android:text="@string/ad_setting_about_feedback_type_bug"
            style="@style/bottom_sheet_option_style" />
        <com.sand.airdroidkid.common.ui.custom.BottomSheetDialogOptionRadioButton
            android:id="@id/btFeedBackItemSuggest"
            android:layout_width="fill_parent"
            android:text="@string/ad_setting_about_feedback_type_suggest"
            style="@style/bottom_sheet_option_style" />
        <com.sand.airdroidkid.common.ui.custom.BottomSheetDialogOptionRadioButton
            android:id="@id/btFeedBackItemBinding"
            android:layout_width="fill_parent"
            android:text="@string/ad_setting_about_feedback_type_binding"
            style="@style/bottom_sheet_option_style" />
        <com.sand.airdroidkid.common.ui.custom.BottomSheetDialogOptionRadioButton
            android:id="@id/btFeedBackItemOther"
            android:layout_width="fill_parent"
            android:text="@string/ad_setting_about_feedback_type_other"
            style="@style/bottom_sheet_option_style" />
    </RadioGroup>
    <TextView
        android:textSize="16.0sp"
        android:textColor="@android:color/white"
        android:id="@id/tvOK"
        android:background="@drawable/kid_blue_button_style"
        android:focusable="true"
        android:layout_width="0.0dip"
        android:layout_marginTop="14.0dip"
        android:text="@string/ad_ok"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/optionGroup"
        style="@style/ad_dlg_base_btn_padding" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/ad_dlg_btn_text_cancel"
        android:gravity="center"
        android:id="@id/tvCancel"
        android:background="@drawable/ad_dlg_btn_color_bg"
        android:focusable="true"
        android:layout_width="0.0dip"
        android:layout_height="44.0dip"
        android:layout_marginTop="6.0dip"
        android:layout_marginBottom="15.0dip"
        android:text="@string/ad_cancel"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOK" />
</androidx.constraintlayout.widget.ConstraintLayout>