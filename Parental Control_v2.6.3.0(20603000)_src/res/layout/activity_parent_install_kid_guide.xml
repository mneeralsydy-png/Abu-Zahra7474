<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clRoot"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/ivMenu"
        android:padding="8.0dip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="13.0dip"
        android:contentDescription="@null"
        android:layout_marginEnd="13.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_more_2" />
    <View
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/viewJoinFamilyRemind"
        android:background="@drawable/red_e13e3e_radius"
        android:visibility="gone"
        android:layout_width="8.0dip"
        android:layout_height="8.0dip"
        android:layout_marginTop="16.0dip"
        android:contentDescription="@null"
        android:layout_marginEnd="20.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivMenu"
        app:layout_constraintWidth_max="@dimen/tablet_max_width">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_start_percent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_end_percent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/glTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/bind_fragment_top_percent" />
        <TextView
            android:id="@id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/parent_user_role_check_kid"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/glTop"
            style="@style/binding_page_title" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/permission_tip"
            android:id="@id/tvDescription"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip"
            android:text="@string/parent_install_kid_guide_title"
            app:layout_constraintEnd_toEndOf="@id/glEnd"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />
        <View
            android:id="@id/viewInfoBackground"
            android:background="@drawable/bg_radius_16_stroke_1"
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_marginTop="16.0dip"
            app:layout_constraintBottom_toBottomOf="@id/spaceBottom"
            app:layout_constraintEnd_toEndOf="@id/glEnd"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintVertical_bias="1.0" />
        <ImageView
            android:id="@id/ivStep1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip"
            android:contentDescription="@null"
            android:layout_marginStart="12.0dip"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintTop_toTopOf="@id/viewInfoBackground"
            app:srcCompat="@drawable/ic_step1_gray" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_282930"
            android:id="@id/tvTitleStep1"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12.0dip"
            android:layout_marginRight="12.0dip"
            android:text="@string/parent_install_kid_guide_step1_title"
            android:layout_marginHorizontal="12.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toStartOf="@id/glEnd"
            app:layout_constraintStart_toEndOf="@id/ivStep1"
            app:layout_constraintTop_toTopOf="@id/ivStep1" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/permission_tip"
            android:id="@id/tvDescStep1"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12.0dip"
            android:layout_marginTop="4.0dip"
            android:layout_marginRight="12.0dip"
            android:text="@string/parent_install_kid_guide_step1_desc"
            android:layout_marginHorizontal="12.0dip"
            app:layout_constraintEnd_toStartOf="@id/glEnd"
            app:layout_constraintStart_toEndOf="@id/ivStep1"
            app:layout_constraintTop_toBottomOf="@id/tvTitleStep1" />
        <ImageView
            android:id="@id/ivStep2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="@id/ivStep1"
            app:layout_constraintStart_toStartOf="@id/ivStep1"
            app:layout_constraintTop_toTopOf="@id/tvTitleStep2"
            app:srcCompat="@drawable/ic_step2_gray" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_282930"
            android:id="@id/tvTitleStep2"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="22.0dip"
            android:text="@string/parent_install_kid_guide_step2_title"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="@id/tvDescStep1"
            app:layout_constraintStart_toStartOf="@id/tvDescStep1"
            app:layout_constraintTop_toBottomOf="@id/tvDescStep1" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/permission_tip"
            android:id="@id/tvDescStep2"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.0dip"
            android:text="@string/parent_install_kid_guide_step2_desc"
            app:layout_constraintEnd_toEndOf="@id/tvTitleStep2"
            app:layout_constraintStart_toStartOf="@id/tvTitleStep2"
            app:layout_constraintTop_toBottomOf="@id/tvTitleStep2" />
        <Button
            android:textSize="16.0sp"
            android:textColor="@color/color_white"
            android:id="@id/btDownload"
            android:background="@drawable/kid_blue_button_style"
            android:layout_width="wrap_content"
            android:layout_height="44.0dip"
            android:layout_marginTop="30.0dip"
            android:text="@string/Common_kids"
            android:drawablePadding="10.0dip"
            android:drawableEnd="@drawable/download_white_circle_blue_arrow"
            android:paddingStart="32.0dip"
            android:paddingEnd="20.0dip"
            android:stateListAnimator="@null"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="@id/glEnd"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintTop_toBottomOf="@id/tvDescStep2" />
        <Space
            android:id="@id/spaceBottom"
            android:layout_width="0.0dip"
            android:layout_height="40.0dip"
            app:layout_constraintStart_toStartOf="@id/btDownload"
            app:layout_constraintTop_toBottomOf="@id/btDownload" />
        <ImageView
            android:id="@id/ivDivider"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            android:layout_marginTop="5.0dip"
            android:layout_marginBottom="5.0dip"
            android:scaleType="fitXY"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:layerType="software"
            app:layout_constraintBottom_toTopOf="@id/ivStep2"
            app:layout_constraintEnd_toEndOf="@id/ivStep1"
            app:layout_constraintStart_toStartOf="@id/ivStep1"
            app:layout_constraintTop_toBottomOf="@id/ivStep1"
            app:layout_constraintVertical_bias="0.0"
            app:srcCompat="@drawable/parent_binding_info_dash_line" />
        <TextView
            android:textColor="@color/black_282930"
            android:id="@id/tvNotNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30.0dip"
            android:text="@string/Parent_No_Continue_Title"
            app:fontFamily="@font/font_family_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintVertical_bias="1.0" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>