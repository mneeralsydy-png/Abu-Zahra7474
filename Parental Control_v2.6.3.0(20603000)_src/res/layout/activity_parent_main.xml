<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:background="@color/color_white"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.fragment.app.FragmentContainerView
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:id="@id/nav_host_fragment"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/barrierBnv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navGraph="@navigation/main_navigation" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrierBnv"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="bnvLayout" />
    <androidx.compose.ui.platform.ComposeView
        android:id="@id/bnvShadowLayout"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/barrierBnv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <androidx.compose.ui.platform.ComposeView
        android:id="@id/bnvLayout"
        android:background="@android:color/transparent"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:translationZ="10.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_min="56.0dip"
        app:layout_constraintStart_toStartOf="parent" />
    <View
        android:id="@id/vNavigationOpenWindowBackground"
        android:background="@color/black_80282930"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:translationZ="20.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nav_host_fragment" />
    <include
        android:id="@id/tutorial_box"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/tutorial_screen" />
</androidx.constraintlayout.widget.ConstraintLayout>