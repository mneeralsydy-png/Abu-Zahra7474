<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/outside"
        android:tag="OutSideView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/ad_bg_white"
        android:layout_width="320.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_centerInParent="true"
        android:elevation="8.0dip"
        android:layout_marginHorizontal="20.0dip">
        <TextView
            android:textSize="18.0sp"
            android:textStyle="bold"
            android:textColor="#ff333333"
            android:id="@id/tvPolicyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip"
            android:text="@string/Account_PrivacyPolicy_Title" />
        <ScrollView
            android:id="@id/svContent"
            android:paddingLeft="20.0dip"
            android:paddingRight="20.0dip"
            android:scrollbars="none"
            android:layout_width="wrap_content"
            android:layout_height="0.0dip"
            android:fillViewport="true"
            android:layout_weight="1.0"
            android:paddingHorizontal="20.0dip">
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@id/llContent"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14.0sp"
                    android:textColor="@color/gray_464f60"
                    android:textColorLink="#ff409eff"
                    android:id="@id/tvPrivateContent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14.0dip"
                    android:text="@string/Account_PrivacyPolicy_Content"
                    android:layout_centerHorizontal="true"
                    android:lineSpacingExtra="5.0dip"
                    android:textAlignment="textStart" />
            </LinearLayout>
        </ScrollView>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@id/llBottom"
            android:paddingLeft="20.0dip"
            android:paddingRight="20.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:minHeight="52.0dip"
            android:paddingHorizontal="20.0dip">
            <TextView
                android:textSize="16.0sp"
                android:textColor="@color/white_ffffff"
                android:id="@id/tvOK"
                android:tag="OK"
                android:background="@drawable/kid_blue_button_style"
                android:layout_width="fill_parent"
                android:layout_marginTop="30.0dip"
                android:text="@string/Account_PrivacyPolicy_Continue"
                app:fontFamily="@font/font_family_semi_bold"
                style="@style/ad_dlg_base_btn_padding" />
            <TextView
                android:textSize="14.0sp"
                android:textColor="@color/gray_878d9a"
                android:id="@id/tvCancel"
                android:tag="Cancel"
                android:layout_width="fill_parent"
                android:layout_marginTop="6.0dip"
                android:layout_marginBottom="12.0dip"
                android:text="@string/Account_PrivacyPolicy_Cancel"
                app:fontFamily="@font/font_family_semi_bold"
                style="@style/ad_dlg_base_btn_padding" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>