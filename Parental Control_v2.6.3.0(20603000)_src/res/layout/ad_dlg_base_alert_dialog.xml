<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    android:layout_gravity="center"
    android:background="@drawable/dialog_radius"
    android:layout_width="@dimen/dialog_max_width"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingBottom="12.0dip"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <View
            android:id="@id/viewCloseExpend"
            android:background="?android:selectableItemBackground"
            android:focusable="true"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="30.0dip"
            android:layout_height="30.0dip"
            android:layout_marginTop="5.0dip"
            android:layout_marginEnd="5.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:id="@id/ivClose"
            android:visibility="gone"
            android:layout_width="14.0dip"
            android:layout_height="14.0dip"
            android:layout_marginTop="14.0dip"
            android:layout_marginEnd="14.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/close" />
        <ImageView
            android:id="@id/ivTitleIcon"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="18.0sp"
            android:textColor="@color/black_ff282930"
            android:gravity="center"
            android:id="@id/tvTitle"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="20.0dip"
            android:layout_marginRight="20.0dip"
            android:text="@string/app_name"
            android:fontFamily="@font/font_family_semi_bold"
            android:layout_marginHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivTitleIcon" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/gray_464f60"
            android:gravity="center"
            android:id="@id/tvMessage"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="12.0dip"
            android:layout_marginRight="20.0dip"
            android:layout_marginHorizontal="20.0dip"
            android:lineHeight="20.0sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@android:color/white"
            android:ellipsize="middle"
            android:id="@id/tvOK"
            android:background="@drawable/kid_blue_button_style"
            android:paddingLeft="20.0dip"
            android:paddingRight="20.0dip"
            android:focusable="true"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="30.0dip"
            android:layout_marginRight="20.0dip"
            android:layout_marginBottom="6.0dip"
            android:text="@string/ad_ok"
            android:maxLines="1"
            android:fontFamily="@font/font_family_semi_bold"
            android:layout_marginHorizontal="20.0dip"
            android:paddingHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintBottom_toTopOf="@id/tvExtraAction"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMessage"
            app:layout_constraintVertical_bias="0.0"
            app:layout_goneMarginBottom="8.0dip"
            style="@style/ad_dlg_base_btn_padding" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@android:color/white"
            android:ellipsize="middle"
            android:id="@id/tvExtraAction"
            android:background="@drawable/kid_red_button_style"
            android:paddingLeft="20.0dip"
            android:paddingRight="20.0dip"
            android:focusable="true"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_marginLeft="20.0dip"
            android:layout_marginRight="20.0dip"
            android:layout_marginBottom="6.0dip"
            android:text="@string/ad_ok"
            android:maxLines="1"
            android:fontFamily="@font/font_family_semi_bold"
            android:layout_marginHorizontal="20.0dip"
            android:paddingHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintBottom_toTopOf="@id/tvCancel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOK"
            app:layout_constraintVertical_bias="0.0"
            app:layout_goneMarginBottom="8.0dip"
            style="@style/ad_dlg_base_btn_padding" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/gray_a4a8b3"
            android:gravity="center"
            android:id="@id/tvCancel"
            android:background="@drawable/ad_dlg_btn_color_bg"
            android:focusable="true"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="44.0dip"
            android:layout_marginLeft="20.0dip"
            android:layout_marginRight="20.0dip"
            android:text="@string/ad_cancel"
            android:fontFamily="@font/font_family_semi_bold"
            android:layout_marginHorizontal="20.0dip"
            app:fontFamily="@font/font_family_medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvExtraAction" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>