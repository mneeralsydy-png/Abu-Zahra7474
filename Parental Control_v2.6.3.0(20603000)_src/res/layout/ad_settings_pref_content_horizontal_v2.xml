<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:gravity="center_vertical"
    android:paddingTop="16.0dip"
    android:paddingBottom="16.0dip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="16.0dip"
    android:paddingEnd="4.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textSize="15.0sp"
        android:textColor="@color/gray_464f60"
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preference Title"
        android:layout_alignParentStart="true" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/ad_preference_sub_title"
        android:id="@id/subTitle"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5.0dip"
        android:text="Preference subTitle"
        android:layout_below="@id/title" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/ad_preference_title"
        android:gravity="start"
        android:id="@id/summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preference Summary"
        android:singleLine="true"
        android:layout_toEndOf="@id/title"
        android:layout_alignParentEnd="true" />
</RelativeLayout>