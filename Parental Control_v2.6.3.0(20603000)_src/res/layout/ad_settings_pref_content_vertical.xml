<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingTop="16.0dip"
    android:paddingBottom="16.0dip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingVertical="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="15.0sp"
            android:id="@id/title"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/st_server_notification"
            android:layout_weight="1.0"
            app:fontFamily="@font/font_family_medium"
            style="@style/ad_settings_pref_title" />
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@id/icon"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ad_base_vip_small" />
    </LinearLayout>
    <TextView
        android:id="@id/summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Preference Summary"
        style="@style/ad_settings_pref_summary" />
</LinearLayout>