<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_gravity="center"
    android:id="@id/rootCardView"
    android:layout_width="@dimen/dialog_max_width"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ad_actionbar_text"
    app:cardCornerRadius="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <View
            android:id="@id/vHeaderTopPadding"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="20.0dip" />
        <ImageView
            android:id="@id/ivHeader"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5.0dip"
            android:layout_marginTop="20.0dip"
            android:layout_marginRight="5.0dip"
            android:src="@drawable/update"
            android:scaleType="fitCenter"
            android:contentDescription="@null"
            android:layout_marginHorizontal="5.0dip" />
        <View
            android:id="@id/vHeaderBottomPadding"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="10.0dip" />
        <TextView
            android:textSize="18.0sp"
            android:textColor="@color/black_ff282930"
            android:gravity="center_horizontal"
            android:id="@id/topTitleBar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="14.0dip"
            android:layout_marginRight="20.0dip"
            android:fontFamily="@font/font_family_semi_bold"
            android:layout_marginHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/gray_464f60"
            android:gravity="center_horizontal"
            android:id="@id/topSubTitleBar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="10.0dip"
            android:layout_marginRight="20.0dip"
            android:layout_marginHorizontal="20.0dip" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="10.0dip"
            android:layout_marginRight="20.0dip"
            android:layout_marginHorizontal="20.0dip">
            <ScrollView
                android:scrollbarSize="3.0dip"
                android:scrollbarThumbVertical="@drawable/custom_scrollbar_thumb"
                android:scrollbarStyle="outsideOverlay"
                android:id="@id/nestedScrollView"
                android:scrollbars="vertical"
                android:layout_width="fill_parent"
                android:layout_height="200.0dip"
                android:fillViewport="true"
                android:layout_weight="1.0"
                android:fadeScrollbars="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.sand.airdroidkid.common.base.SandWebView
                    android:orientation="horizontal"
                    android:id="@id/webView"
                    android:focusable="true"
                    android:scrollbars="none"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10.0dip"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </ScrollView>
            <ProgressBar
                android:layout_gravity="center"
                android:id="@id/pbProgress"
                android:layout_width="30.0dip"
                android:layout_height="30.0dip"
                android:max="100"
                android:progress="50"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/nestedScrollView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/nestedScrollView" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="horizontal"
            android:id="@id/llBtnPane"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginRight="20.0dip"
            android:layout_marginBottom="10.0dip"
            android:layout_marginHorizontal="20.0dip">
            <Button
                android:textSize="16.0sp"
                android:textColor="@android:color/white"
                android:id="@id/btPositive"
                android:background="@drawable/kid_blue_button_style"
                android:layout_width="0.0dip"
                android:layout_height="44.0dip"
                android:layout_marginLeft="6.0dip"
                android:layout_marginTop="20.0dip"
                android:layout_marginRight="6.0dip"
                android:text="@string/Common_OK2"
                android:textAllCaps="false"
                android:layout_marginHorizontal="6.0dip"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <Button
                android:textSize="14.0sp"
                android:textColor="@color/text_400"
                android:id="@id/btNegative"
                android:background="@drawable/ad_dlg_btn_color_bg"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="6.0dip"
                android:layout_marginTop="6.0dip"
                android:layout_marginRight="6.0dip"
                android:text="@string/ad_cancel"
                android:textAllCaps="false"
                android:layout_marginHorizontal="6.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btPositive"
                style="@style/Widget.AppCompat.Button.Borderless" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>