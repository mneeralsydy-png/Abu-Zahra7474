<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/white_ffffff"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.appcompat.widget.Toolbar
        android:id="@id/tbOverhear"
        android:background="@android:color/white"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        android:minHeight="?actionBarSize"
        android:elevation="0.0dip"
        app:contentInsetStartWithNavigation="0.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/kid_list_listen_title"
        app:titleMargin="0.0dip"
        app:titleTextAppearance="@style/CommonAppTheme.ToolBarTitleTextAppearance"
        app:titleTextColor="@color/black_282930" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clOverhearContent"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toTopOf="@id/btOverhearRecord"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tbOverhear">
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/gray_878d9a"
            android:id="@id/tvOverhearState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Device_Listening_Subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="18.0sp"
            android:textColor="@color/black_282930"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvOverhearDeviceModel"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="4.0dip"
            android:layout_marginRight="20.0dip"
            android:maxLines="1"
            android:layout_marginHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOverhearState" />
        <com.sand.airdroidkidp.ui.custom.SimpleSurfaceView
            android:id="@id/lottieAnimationView"
            android:layout_width="190.0dip"
            android:layout_height="190.0dip"
            android:layout_marginTop="50.0dip"
            app:assetsFileName="recording.mp4"
            app:autoPlay="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOverhearDeviceModel"
            app:loop="true"
            app:placeholder="@drawable/pic_recording"
            app:placeholderBackground="@color/white_ffffff" />
        <TextView
            android:textSize="30.0sp"
            android:textColor="@color/black_282930"
            android:gravity="center"
            android:id="@id/tvOverhearTimeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip"
            android:text="00:00"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lottieAnimationView" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clRecordCountDown"
        android:background="@drawable/bg_radius_16_stroke_1"
        android:paddingLeft="14.0dip"
        android:paddingRight="14.0dip"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="34.0dip"
        android:layout_marginLeft="20.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_marginHorizontal="20.0dip"
        android:paddingHorizontal="14.0dip"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toTopOf="@id/btOverhearRecord"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clOverhearContent">
        <View
            android:id="@id/vRecordMark"
            android:background="@drawable/blue_dot"
            android:layout_width="8.0dip"
            android:layout_height="8.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_282930"
            android:id="@id/tvRecordTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Device_Listening_Recording"
            android:layout_marginStart="6.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toEndOf="@id/vRecordMark"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_282930"
            android:gravity="end"
            android:id="@id/tvOverhearRecordTimeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvRecordTitle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_min="64.0dip" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <Button
        android:id="@id/btOverhearRecord"
        android:background="@drawable/record_start"
        android:layout_width="60.0dip"
        android:layout_height="60.0dip"
        android:layout_marginBottom="100.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        style="?android:borderlessButtonStyle" />
</androidx.constraintlayout.widget.ConstraintLayout>