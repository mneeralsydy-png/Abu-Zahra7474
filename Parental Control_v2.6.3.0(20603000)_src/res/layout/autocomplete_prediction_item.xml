<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/autocomplete_prediction_container"
        android:paddingTop="?placesSpacingSmall"
        android:paddingBottom="?placesSpacingSmall"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="?placesSpacingMedium"
        android:paddingEnd="?placesSpacingMedium">
        <FrameLayout
            android:id="@id/list_item_icon_container"
            android:layout_width="@dimen/gmp_sys_measurement_icon_size_large"
            android:layout_height="@dimen/gmp_sys_measurement_icon_size_large"
            android:layout_marginEnd="?placesSpacingMedium">
            <ImageView
                android:id="@id/list_item_icon_background"
                android:layout_width="@dimen/gmp_sys_measurement_icon_size_large"
                android:layout_height="@dimen/gmp_sys_measurement_icon_size_large"
                android:src="@drawable/autocomplete_list_item_icon_background"
                android:contentDescription="@null"
                android:importantForAccessibility="no" />
            <ImageView
                android:layout_gravity="center"
                android:id="@id/list_item_icon"
                android:layout_width="@dimen/gmp_sys_measurement_icon_size_small"
                android:layout_height="@dimen/gmp_sys_measurement_icon_size_small"
                android:src="@drawable/location_on_icon"
                android:tint="?placesColorOnNeutralContainer"
                android:contentDescription="@null"
                android:importantForAccessibility="no" />
        </FrameLayout>
        <LinearLayout
            android:layout_gravity="center"
            android:orientation="vertical"
            android:id="@id/autocomplete_prediction_text_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textAppearance="?placesTextAppearanceLabelLarge"
                android:textColor="?placesColorOnSurface"
                android:ellipsize="end"
                android:id="@id/autocomplete_prediction_primary_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1.0" />
            <TextView
                android:textAppearance="?placesTextAppearanceBodySmall"
                android:textColor="?placesColorOnSurfaceVariant"
                android:ellipsize="end"
                android:id="@id/autocomplete_prediction_secondary_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1.0" />
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@id/autocomplete_prediction_list_separator"
        android:background="?placesColorOutlineDecorative"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/place_widget_border_width" />
</LinearLayout>