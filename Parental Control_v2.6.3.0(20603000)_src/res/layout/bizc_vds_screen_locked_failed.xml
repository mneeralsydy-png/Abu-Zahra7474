<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:id="@id/ll_vds_connection_fail"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20.0dip"
        app:layout_constraintBottom_toTopOf="@id/vdsScreenLockedFailedGroup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/pic_device_locking" />
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/vdsScreenLockedFailedGroup"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_marginHorizontal="20.0dip"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintWidth_max="@dimen/tablet_max_width">
        <TextView
            android:theme="@style/webrtc_connecting_title"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/vds_screen_locked_failed_title"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Device_Screenshot_Locked_Title" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_ff464f60"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/vds_screen_locked_failed_tip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.0dip"
            android:text="@string/Parent_Device_Screenshot_Locked_Content" />
    </LinearLayout>
    <Button
        android:textSize="16.0sp"
        android:textColor="@color/white_ffffff"
        android:id="@id/button_screen_locked_failed_got_it"
        android:background="@drawable/kid_blue_button_style"
        android:layout_width="0.0dip"
        android:layout_height="44.0dip"
        android:layout_marginLeft="20.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_marginBottom="30.0dip"
        android:text="@string/Common_gotit_tip"
        android:layout_marginHorizontal="20.0dip"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="@dimen/tablet_max_width"
        style="?android:borderlessButtonStyle" />
</androidx.constraintlayout.widget.ConstraintLayout>