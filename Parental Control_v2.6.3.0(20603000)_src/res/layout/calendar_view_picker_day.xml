<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:background="@null"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:stateListAnimator="@null"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:gravity="center"
        android:background="@drawable/day_picker_item_background"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_margin="1.0dip"
        app:layout_constraintBottom_toBottomOf="@id/dayLabel"
        app:layout_constraintDimensionRatio="w,1:1"
        app:layout_constraintEnd_toEndOf="@id/dayLabel"
        app:layout_constraintStart_toStartOf="@id/dayLabel"
        app:layout_constraintTop_toTopOf="@id/dayLabel" />
    <View
        android:id="@id/viewStartBackground"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/dayLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/dayLabel"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.5" />
    <View
        android:id="@id/viewEndBackground"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/dayLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/dayLabel"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.5" />
    <TextView
        android:textSize="14.0sp"
        android:gravity="center"
        android:id="@id/dayLabel"
        android:padding="4.0dip"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_margin="3.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="w,1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="@dimen/day_label_size_events_disabled"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="@dimen/day_label_size_events_disabled" />
</androidx.constraintlayout.widget.ConstraintLayout>