<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_gravity="center"
    android:orientation="vertical"
    android:background="@drawable/places_widgets_dialog_background"
    android:padding="?placesSpacingTwoExtraLarge"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="?placesSpacingTwoExtraLarge"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textAppearance="?placesTextAppearanceHeadlineMedium"
        android:textColor="?placesColorOnSurface"
        android:id="@id/cma_details_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <TextView
        android:textAppearance="?placesTextAppearanceBodyMedium"
        android:textColor="?placesColorOnSurface"
        android:id="@id/cma_details_description"
        android:paddingTop="?placesSpacingSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <TextView
        android:textAppearance="?placesTextAppearanceLabelLarge"
        android:textColor="?placesColorPrimary"
        android:gravity="center_vertical"
        android:id="@id/cma_details_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="?placesSpacingMedium"
        android:minHeight="@dimen/min_touch_target_size_for_a11y"
        android:drawablePadding="?placesSpacingExtraSmall"
        android:drawableEnd="@drawable/open_in_new"
        android:drawableTint="?placesColorPrimary" />
    <Button
        android:textAppearance="?placesTextAppearanceLabelLarge"
        android:textColor="?placesColorOnSecondaryContainer"
        android:id="@id/cma_alert_ok"
        android:background="@drawable/places_widgets_button_background"
        android:paddingTop="?placesSpacingExtraSmall"
        android:paddingBottom="?placesSpacingExtraSmall"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/places_dialogs_ok_button"
        android:stateListAnimator="@null" />
</LinearLayout>