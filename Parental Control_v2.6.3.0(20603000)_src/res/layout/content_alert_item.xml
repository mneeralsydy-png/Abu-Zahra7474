<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clContentAlertItem"
    android:background="@drawable/usage_limit_bg"
    android:paddingLeft="16.0dip"
    android:paddingTop="16.0dip"
    android:paddingRight="16.0dip"
    android:paddingBottom="16.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/list_item_divider"
    android:paddingHorizontal="16.0dip"
    android:paddingVertical="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@id/ivIcon"
        android:background="@drawable/icon_app_bg"
        android:padding="1.0dip"
        android:layout_width="22.0dip"
        android:layout_height="22.0dip"
        android:src="@drawable/ic_noapp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:ellipsize="end"
        android:id="@id/tvTitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10.0dip"
        android:layout_marginRight="10.0dip"
        android:maxLines="1"
        android:textDirection="locale"
        android:layout_marginHorizontal="10.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintBottom_toBottomOf="@id/ivIcon"
        app:layout_constraintEnd_toStartOf="@id/tvTime"
        app:layout_constraintStart_toEndOf="@id/ivIcon"
        app:layout_constraintTop_toTopOf="@id/ivIcon" />
    <TextView
        android:textSize="12.0sp"
        android:textColor="@color/grey_a4a8b3"
        android:id="@id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/ivIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvTitle"
        app:layout_constraintTop_toTopOf="@id/ivIcon" />
    <View
        android:id="@id/divider"
        android:background="@color/white_f5f5f5"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip"
        android:layout_marginTop="16.0dip"
        app:layout_constraintBottom_toTopOf="@id/tvKeywordTitle"
        app:layout_constraintTop_toBottomOf="@id/ivIcon" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/grey_a4a8b3"
        android:id="@id/tvKeywordTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        android:text="@string/Parent_Keyword_Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/grey_a4a8b3"
        android:id="@id/tvSourceTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        android:text="@string/Parent_Keyword_Detect_Source"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvKeywordTitle" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/grey_a4a8b3"
        android:id="@id/tvContentDetailTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        android:text="@string/Parent_Keyword_Detect_Content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSourceTitle" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrierTitleEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="tvContentDetailTitle, tvKeywordTitle, tvSourceTitle, tvImageTitle" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/gray_464f60"
        android:ellipsize="end"
        android:id="@id/tvKeyword"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textAlignment="viewStart"
        android:layout_marginStart="20.0dip"
        app:layout_constraintBottom_toBottomOf="@id/tvKeywordTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/barrierTitleEnd"
        app:layout_constraintTop_toTopOf="@id/tvKeywordTitle" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/gray_464f60"
        android:ellipsize="end"
        android:id="@id/tvSource"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textAlignment="viewStart"
        android:layout_marginStart="20.0dip"
        app:layout_constraintBottom_toBottomOf="@id/tvSourceTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/barrierTitleEnd"
        app:layout_constraintTop_toTopOf="@id/tvSourceTitle" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/gray_464f60"
        android:ellipsize="end"
        android:id="@id/tvContentDetail"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:textAlignment="viewStart"
        android:layout_marginStart="20.0dip"
        app:layout_constraintBottom_toTopOf="@id/barrierImageBottom"
        app:layout_constraintEnd_toStartOf="@id/ivToggle"
        app:layout_constraintStart_toEndOf="@id/barrierTitleEnd"
        app:layout_constraintTop_toTopOf="@id/tvContentDetailTitle" />
    <ImageView
        android:id="@id/ivToggle"
        android:padding="6.0dip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/more"
        android:contentDescription="@null"
        android:rotation="90.0"
        app:layout_constraintBottom_toBottomOf="@id/tvContentDetailTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toEndOf="@id/tvContentDetail"
        app:layout_constraintTop_toTopOf="@id/tvContentDetailTitle" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/barrierImageBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="tvContentDetailTitle, tvContentDetail" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/grey_a4a8b3"
        android:id="@id/tvImageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16.0dip"
        android:text="@string/Device_Keyword_Screenshot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/barrierImageBottom" />
    <androidx.compose.ui.platform.ComposeView
        android:id="@id/composeView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20.0dip"
        app:layout_constraintStart_toEndOf="@id/barrierTitleEnd"
        app:layout_constraintTop_toTopOf="@id/tvImageTitle" />
</androidx.constraintlayout.widget.ConstraintLayout>