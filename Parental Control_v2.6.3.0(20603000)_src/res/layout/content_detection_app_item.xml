<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="@dimen/global_start_percent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="@dimen/global_end_percent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/item"
        android:paddingLeft="16.0dip"
        android:paddingRight="16.0dip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16.0dip"
        app:layout_constraintEnd_toEndOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@id/ivAppListIcon"
            android:background="@drawable/icon_app_bg"
            android:padding="1.0dip"
            android:layout_width="30.0dip"
            android:layout_height="30.0dip"
            android:src="@drawable/ic_noapp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/black_282930"
            android:ellipsize="end"
            android:id="@id/tvAppListName"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dip"
            android:layout_marginBottom="4.0dip"
            android:textDirection="locale"
            android:layout_marginStart="14.0dip"
            android:layout_marginEnd="10.0dip"
            app:fontFamily="@font/font_family_medium"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toTopOf="@id/tvAppDescribe"
            app:layout_constraintEnd_toStartOf="@id/tgEnableAlert"
            app:layout_constraintStart_toEndOf="@id/ivAppListIcon"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/gray_ff878d9a"
            android:ellipsize="end"
            android:id="@id/tvAppDescribe"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.0dip"
            android:textDirection="locale"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="@id/tvAppListName"
            app:layout_constraintStart_toStartOf="@id/tvAppListName"
            app:layout_constraintTop_toBottomOf="@id/tvAppListName" />
        <ToggleButton
            android:id="@id/tgEnableAlert"
            android:background="@drawable/toggle_button"
            android:saveEnabled="false"
            android:layout_width="42.0dip"
            android:layout_height="24.0dip"
            android:checked="false"
            android:textOn=""
            android:textOff=""
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <View
            android:id="@id/vDivider"
            android:background="@color/gray_ececee"
            android:visibility="visible"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            android:layout_marginTop="16.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvAppListName"
            app:layout_constraintTop_toBottomOf="@id/tvAppDescribe" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>