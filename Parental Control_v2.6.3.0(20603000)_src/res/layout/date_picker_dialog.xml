<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <FrameLayout
        android:id="@id/calendarContainer"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_marginHorizontal="20.0dip" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="fill_parent"
        android:layout_height="88.0dip"
        android:layout_marginLeft="20.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_marginBottom="10.0dip"
        android:layout_marginHorizontal="20.0dip">
        <androidx.appcompat.widget.AppCompatButton
            android:id="@id/today_button"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/material_calendar_today_button"
            android:layout_marginStart="8.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Widget.AppCompat.Button.Borderless.Colored" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@id/positive_button"
            android:layout_width="0.0dip"
            android:layout_height="44.0dip"
            android:text="@string/material_calendar_positive_button"
            android:textAllCaps="false"
            app:fontFamily="@font/inter_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Widget.AppCompat.Button.Borderless.Colored" />
        <androidx.appcompat.widget.AppCompatButton
            android:id="@id/negative_button"
            android:layout_width="0.0dip"
            android:layout_height="44.0dip"
            android:text="@string/material_calendar_negative_button"
            android:textAllCaps="false"
            app:fontFamily="@font/inter_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/positive_button"
            style="@style/Widget.AppCompat.Button.Borderless.Colored" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>