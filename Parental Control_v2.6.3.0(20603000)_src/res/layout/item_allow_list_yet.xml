<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clBackGround"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/spacer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/clAllowListItem"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:textSize="12.0sp"
                android:layout_gravity="center"
                android:id="@id/ivMinus"
                android:layout_width="20.0dip"
                android:layout_height="20.0dip"
                android:src="@drawable/prohibit"
                android:text="@string/Parent_Setting_Records_Delete"
                android:layout_marginStart="15.0dip"
                android:layout_marginEnd="14.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivAllowAppIcon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <ImageView
                android:id="@id/ivAllowAppIcon"
                android:background="@drawable/icon_app_bg"
                android:padding="1.0dip"
                android:layout_width="30.0dip"
                android:layout_height="30.0dip"
                android:layout_marginTop="12.0dip"
                android:layout_marginBottom="12.0dip"
                android:src="@drawable/ic_noapp"
                android:layout_marginVertical="12.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvAllowApp"
                app:layout_constraintStart_toEndOf="@id/ivMinus"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_goneMarginStart="15.0dip" />
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/black_282930"
                android:ellipsize="end"
                android:id="@id/tvAllowApp"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textDirection="locale"
                android:layout_marginStart="10.0dip"
                android:layout_marginEnd="15.0dip"
                app:fontFamily="@font/font_family_medium"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivAllowAppIcon"
                app:layout_constraintTop_toTopOf="parent" />
            <View
                android:id="@id/vDivider"
                android:background="@color/ad_base_divider"
                android:layout_width="0.0dip"
                android:layout_height="1.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/ivAllowAppIcon" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:textSize="12.0sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@id/tvDelete"
            android:background="@color/kid_guide_err_txt"
            android:layout_width="76.0dip"
            android:layout_height="0.0dip"
            android:text="@string/Parent_Setting_Records_Delete"
            android:layout_marginStart="1.0dip"
            app:layout_constraintBottom_toBottomOf="@id/clAllowListItem"
            app:layout_constraintStart_toEndOf="@id/clAllowListItem"
            app:layout_constraintTop_toTopOf="@id/clAllowListItem" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@id/spacer"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="10.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clBackGround" />
</androidx.constraintlayout.widget.ConstraintLayout>