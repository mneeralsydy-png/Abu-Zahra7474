<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clToggle"
    android:background="@drawable/item_app_detail_usage_limit_bg"
    android:padding="16.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toTopOf="@id/tvAllAppTitle"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <TextView
        android:textSize="15.0sp"
        android:textColor="@color/black_282930"
        android:id="@id/tvToggleTitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:text="@string/Parent_UsageLimit_Forbid_All_Title"
        android:layout_marginEnd="18.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintEnd_toStartOf="@id/tbAllApps"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ToggleButton
        android:id="@id/tbAllApps"
