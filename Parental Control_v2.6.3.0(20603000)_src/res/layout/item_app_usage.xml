<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="20.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="20.0dip" />
    <TextView
        android:textSize="13.0sp"
        android:id="@id/tvUsageTimeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Parent_TodayEvent_Device_Usage_Time"
        android:layout_marginEnd="5.0dip"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/tvMoreDetail"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_min="80.0dip" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/blue_446efc"
        android:gravity="end"
        android:id="@id/tvMoreDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Parent_TodayEvent_Look_More"
        android:layout_marginStart="5.0dip"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toEndOf="@id/glEnd"
        app:layout_constraintStart_toEndOf="@id/tvUsageTimeTitle"
        app:layout_constraintTop_toTopOf="@id/tvUsageTimeTitle" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/item_app_detail_bg"
        android:paddingBottom="20.0dip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvUsageTimeTitle">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glContentStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_begin="20.0dip" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glContentEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_end="20.0dip" />
        <TextView
            android:textSize="24.0sp"
            android:textColor="@color/black_2d2f33"
            android:id="@id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintStart_toStartOf="@id/glContentStart"
            app:layout_constraintTop_toTopOf="parent" />
        <com.github.mikephil.charting.charts.BarChart
            android:id="@id/bcContent"
            android:layout_width="0.0dip"
            android:layout_height="85.0dip"
            android:layout_marginTop="16.0dip"
            android:layout_marginStart="5.0dip"
            app:layout_constraintEnd_toEndOf="@id/glContentEnd"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLastWeekTitle" />
        <com.sand.airdroidkidp.ui.custom.ParentAppDetailTextPreference
            android:id="@id/usageAva"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            app:layout_constraintEnd_toEndOf="@id/glContentEnd"
            app:layout_constraintStart_toStartOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/bcContent"
            app:title="@string/Parent_TodayEvent_Average" />
        <com.sand.airdroidkidp.ui.custom.ParentAppDetailTextPreference
            android:id="@id/notification"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            app:layout_constraintEnd_toEndOf="@id/glContentEnd"
            app:layout_constraintStart_toStartOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/usageAva"
            app:title="@string/Parent_TodayEvent_Notification_Week" />
        <com.sand.airdroidkidp.ui.custom.ParentAppDetailTextPreference
            android:id="@id/flowSum"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            app:layout_constraintEnd_toEndOf="@id/glContentEnd"
            app:layout_constraintStart_toStartOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/notification"
            app:title="@string/Parent_TodayEvent_Usage_Flow_Title" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/gray_ff878d9a"
            android:id="@id/tvLastWeekTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6.0dip"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toStartOf="@id/tvSubIcon"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/tvTotalTime" />
        <ImageView
            android:id="@id/tvSubIcon"
            android:layout_width="14.0dip"
            android:layout_height="14.0dip"
            android:layout_marginStart="8.0dip"
            app:layout_constraintBottom_toBottomOf="@id/tvLastWeekTitle"
            app:layout_constraintEnd_toStartOf="@id/tvSubContent"
            app:layout_constraintStart_toEndOf="@id/tvLastWeekTitle"
            app:layout_constraintTop_toTopOf="@id/tvLastWeekTitle" />
        <TextView
            android:textSize="12.0sp"
            android:id="@id/tvSubContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintBottom_toBottomOf="@id/tvLastWeekTitle"
            app:layout_constraintEnd_toEndOf="@id/glContentEnd"
            app:layout_constraintStart_toEndOf="@id/tvSubIcon"
            app:layout_constraintTop_toTopOf="@id/tvLastWeekTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>