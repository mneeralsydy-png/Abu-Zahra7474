<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/box"
    android:background="@drawable/usage_limit_bg"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@id/glTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="12.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="16.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="16.0dip" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/text_100"
        android:ellipsize="end"
        android:id="@id/tvLimitName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:drawablePadding="4.0dip"
        android:textDirection="locale"
        android:layout_marginEnd="10.0dip"
        app:drawableEndCompat="@drawable/more"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/textNotEnabled"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="@id/glTop"
        app:layout_goneMarginEnd="0.0dip" />
    <TextView
        android:textSize="12.0sp"
        android:textColor="@color/text_200"
        android:id="@id/textNotEnabled"
        android:background="@drawable/bg_not_enabled_tag"
        android:paddingLeft="5.0dip"
        android:paddingRight="5.0dip"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="16.0dip"
        android:text="@string/Parent_UsageLimit_Not_Enable"
        android:maxLines="1"
        android:layout_marginEnd="4.0dip"
        android:paddingHorizontal="5.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintBottom_toBottomOf="@id/tvLimitName"
        app:layout_constraintEnd_toEndOf="@id/glEnd"
        app:layout_constraintTop_toTopOf="@id/tvLimitName" />
    <ImageView
        android:id="@id/ivRule"
        android:visibility="gone"
        android:layout_width="14.0dip"
        android:layout_height="14.0dip"
        android:src="@drawable/stopwatch"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="@id/tvItemSubName"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="@id/tvItemSubName" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:ellipsize="end"
        android:id="@id/tvItemSubName"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:maxLines="1"
        android:textDirection="locale"
        android:layout_marginStart="2.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintStart_toEndOf="@id/ivRule"
        app:layout_constraintTop_toBottomOf="@id/tvLimitName"
        app:layout_goneMarginStart="0.0dip" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/gray_878d9a"
        android:ellipsize="end"
        android:id="@id/tvItemComment"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.0dip"
        android:maxLines="1"
        android:textDirection="locale"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvItemSubName" />
    <View
        android:id="@id/divider"
        android:background="@color/gray_ececee"
        android:layout_width="0.0dip"
        android:layout_height="1.0dip"
        android:layout_marginTop="12.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvItemComment" />
</androidx.constraintlayout.widget.ConstraintLayout>