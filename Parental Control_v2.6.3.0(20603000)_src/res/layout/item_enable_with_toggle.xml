<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clItemEnableToggle"
    android:background="@drawable/item_bg200_radius16_click_background"
    android:paddingTop="16.0dip"
    android:paddingBottom="16.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="16.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="16.0dip" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/black_282930"
        android:ellipsize="end"
        android:id="@id/tvItemName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:drawablePadding="4.0dip"
        android:textDirection="locale"
        android:layout_marginEnd="20.0dip"
        app:drawableEndCompat="@drawable/more"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/tgEnableItem"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="parent" />
    <ToggleButton
        android:id="@id/tgEnableItem"
        android:background="@drawable/toggle_button"
        android:layout_width="42.0dip"
        android:layout_height="24.0dip"
        android:checked="true"
        android:textOn=""
        android:textOff=""
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/glEnd"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@id/ivRule"
        android:visibility="gone"
        android:layout_width="14.0dip"
        android:layout_height="14.0dip"
        android:src="@drawable/stopwatch"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="@id/tvRuleTime"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="@id/tvRuleTime" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:ellipsize="end"
        android:id="@id/tvRuleTime"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:textDirection="locale"
        android:layout_marginStart="2.0dip"
        android:layout_marginEnd="20.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintEnd_toStartOf="@id/tgEnableItem"
        app:layout_constraintStart_toEndOf="@id/ivRule"
        app:layout_constraintTop_toBottomOf="@id/tvItemName" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:ellipsize="end"
        android:id="@id/tvItemSubName"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:maxLines="1"
        android:textDirection="locale"
        android:layout_marginEnd="20.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintEnd_toStartOf="@id/tgEnableItem"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvItemName" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/rule_place_barrier"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:barrierDirection="bottom"
        app:constraint_referenced_ids="tvRuleTime,tvItemSubName" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/gray_878d9a"
        android:ellipsize="end"
        android:id="@id/tvItemComment"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="2.0dip"
        android:maxLines="1"
        android:textDirection="locale"
        android:layout_marginEnd="20.0dip"
        app:layout_constraintEnd_toStartOf="@id/tgEnableItem"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/rule_place_barrier" />
</androidx.constraintlayout.widget.ConstraintLayout>