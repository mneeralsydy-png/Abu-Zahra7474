<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/infoCard"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:id="@id/rlTopEvent"
        android:background="@drawable/bg_radius_16_stroke_1"
        android:paddingLeft="16.0dip"
        android:paddingTop="16.0dip"
        android:paddingRight="16.0dip"
        android:paddingBottom="15.0dip"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5.0dip"
        android:layout_marginBottom="26.0dip"
        android:layout_marginStart="5.0dip"
        android:layout_marginEnd="5.0dip"
        android:elevation="5.0dip"
        android:paddingHorizontal="16.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/rlAvatar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@id/ivAvatar"
                android:layout_width="30.0dip"
                android:layout_height="30.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/account" />
            <TextView
                android:textSize="16.0sp"
                android:textColor="@color/black_282930"
                android:ellipsize="end"
                android:id="@id/tvDeviceModel"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:lines="1"
                android:layout_centerVertical="true"
                android:textDirection="locale"
                android:layout_marginStart="10.0dip"
                android:layout_marginEnd="10.0dip"
                app:fontFamily="@font/font_family_semi_bold"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
                app:layout_constraintEnd_toStartOf="@id/ivNavigation"
                app:layout_constraintStart_toEndOf="@id/ivAvatar"
                app:layout_constraintTop_toTopOf="@id/ivAvatar" />
            <ImageView
                android:id="@id/ivNavigation"
                android:background="@drawable/btn_map_navigation"
                android:layout_width="28.0dip"
                android:layout_height="28.0dip"
                android:layout_marginEnd="10.0dip"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
                app:layout_constraintEnd_toStartOf="@id/ivRefresh"
                app:layout_constraintTop_toTopOf="@id/ivAvatar" />
            <ImageView
                android:id="@id/ivRefresh"
                android:background="@drawable/refresh"
                android:layout_width="28.0dip"
                android:layout_height="28.0dip"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivAvatar" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10.0dip"
            android:layout_below="@id/rlAvatar">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/vLocationTitleParent"
                android:paddingLeft="6.0dip"
                android:paddingRight="6.0dip"
                android:layout_width="wrap_content"
                android:layout_height="22.0dip"
                android:paddingHorizontal="6.0dip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@id/tvLocationTitleIcon"
                    android:layout_width="13.0dip"
                    android:layout_height="13.0dip"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:textSize="12.0sp"
                    android:ellipsize="end"
                    android:id="@id/tvLocationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:layout_marginStart="5.0dip"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvLocationTitleIcon"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textSize="13.0sp"
                android:textColor="@color/gray_464f60"
                android:ellipsize="end"
                android:id="@id/tvLocationMessage"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip"
                android:lines="2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/vLocationTitleParent" />
            <TextView
                android:textSize="13.0sp"
                android:textColor="@color/gray_464f60"
                android:gravity="center_vertical"
                android:id="@id/tvStatusMessage"
                android:background="@color/white_ffffff"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:text="@string/Parent_Position_No_Network_Toast"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>