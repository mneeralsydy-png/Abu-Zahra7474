<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/parent_device_hint_bg"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6.0dip"
    android:alpha="0.8"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/ivHintIcon"
        android:layout_width="24.0dip"
        android:layout_height="24.0dip"
        android:layout_marginStart="16.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/icon_tips_2" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/color_white"
        android:id="@id/tvHintMessage"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_margin="16.0dip"
        android:text="@string/Parent_Location_Battery_Tip"
        android:lineSpacingMultiplier="1.2"
        android:lineHeight="18.0sp"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivCloseButton"
        app:layout_constraintStart_toEndOf="@id/ivHintIcon"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@id/ivCloseButton"
        android:background="@drawable/icon_close"
        android:layout_width="24.0dip"
        android:layout_height="24.0dip"
        android:layout_marginEnd="20.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>