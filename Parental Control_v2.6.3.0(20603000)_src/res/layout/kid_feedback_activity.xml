<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:id="@id/clRoot"
    android:background="@android:color/white"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@android:color/white"
        android:paddingBottom="20.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/guidelineStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintGuide_percent="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/guidelineEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintGuide_percent="0.95"
            app:layout_constraintTop_toTopOf="parent" />
        <androidx.appcompat.widget.Toolbar
            android:id="@id/toolbar"
            android:background="@android:color/white"
            android:layout_width="fill_parent"
            android:layout_height="?actionBarSize"
            app:contentInsetStartWithNavigation="0.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:navigationIcon="@drawable/ic_back"
            app:titleMargin="0.0dip"
            app:titleTextAppearance="@style/CommonAppTheme.ToolBarTitleTextAppearance"
            app:titleTextColor="@color/black_ff282930" />
        <RelativeLayout
            android:gravity="center_vertical"
            android:id="@id/rlMail"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:layout_marginBottom="8.0dip"
            android:layout_marginVertical="8.0dip"
            app:layout_constraintEnd_toStartOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/toolbar">
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/black_ff282930"
                android:id="@id/tvMail"
                android:paddingTop="16.0dip"
                android:paddingBottom="16.0dip"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fb_email"
                android:layout_alignParentStart="true"
                android:paddingVertical="16.0dip"
                app:fontFamily="@font/font_family_medium" />
            <EditText
                android:textSize="15.0sp"
                android:textColor="@color/black_ff282930"
                android:textColorHint="@color/gray_666b75"
                android:id="@id/etMail"
                android:background="@null"
                android:focusable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:hint="@string/fb_please_input_email"
                android:singleLine="true"
                android:layout_weight="1.0"
                android:layout_centerVertical="true"
                android:imeOptions="actionNext"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textDirection="locale"
                android:layout_marginStart="20.0dip"
                android:layout_toEndOf="@id/tvMail" />
        </RelativeLayout>
        <View
            android:id="@id/view2"
            android:background="@color/ad_base_divider3"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/rlMail" />
        <RelativeLayout
            android:gravity="center_horizontal"
            android:id="@id/relativeLayout2"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:layout_marginBottom="8.0dip"
            android:layout_marginVertical="8.0dip"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/rlMail">
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/black_ff282930"
                android:id="@id/tvFeedbackTitle"
                android:paddingTop="16.0dip"
                android:paddingBottom="16.0dip"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ad_setting_about_feedback_type"
                android:layout_alignParentStart="true"
                android:paddingVertical="16.0dip"
                app:fontFamily="@font/font_family_medium" />
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/gray_ff878d9a"
                android:id="@id/tvFeedbackOption"
                android:background="@drawable/ad_actionbar_item_selector"
                android:focusable="true"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:text="@string/ad_setting_about_feedback_type_bug"
                android:layout_centerVertical="true"
                android:layout_marginStart="20.0dip"
                android:layout_marginEnd="16.0dip"
                android:layout_toEndOf="@id/tvFeedbackTitle"
                app:drawableEndCompat="@drawable/more" />
        </RelativeLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="center_horizontal"
            android:id="@id/deviceSelector"
            android:visibility="gone"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/relativeLayout2">
            <View
                android:id="@id/deviceDivider"
                android:background="@color/ad_base_divider3"
                android:layout_width="fill_parent"
                android:layout_height="1.0dip"
                android:layout_marginStart="16.0dip"
                android:layout_marginEnd="16.0dip"
                app:layout_constraintBottom_toTopOf="@id/tvDeviceTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:textSize="15.0sp"
                android:textColor="#de000000"
                android:id="@id/tvDeviceTitle"
                android:paddingTop="16.0dip"
                android:paddingBottom="16.0dip"
                android:focusable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8.0dip"
                android:text="@string/Parent_Device_Select_Title"
                android:paddingVertical="16.0dip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/deviceDivider" />
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/gray_ff878d9a"
                android:ellipsize="end"
                android:id="@id/tvDeviceOption"
                android:background="@drawable/ad_actionbar_item_selector"
                android:focusable="true"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:text="@string/Common_none"
                android:maxLines="1"
                android:layout_marginStart="20.0dip"
                android:layout_marginEnd="16.0dip"
                app:drawableEndCompat="@drawable/more"
                app:layout_constraintBottom_toBottomOf="@id/tvDeviceTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvDeviceTitle"
                app:layout_constraintTop_toTopOf="@id/tvDeviceTitle" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@id/view3"
            android:background="@color/ad_base_divider3"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/deviceSelector" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/clFeedbackContent"
            android:background="@drawable/ad_base_list_item_bg"
            android:paddingTop="18.0dip"
            android:paddingBottom="8.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/view3">
            <EditText
                android:scrollbarStyle="insideInset"
                android:textSize="13.0sp"
                android:textColor="@color/black_ff282930"
                android:textColorHint="@color/gray_666b75"
                android:gravity="start"
                android:id="@id/etFeedbackContent"
                android:background="@drawable/default_edit_text_bg"
                android:paddingTop="12.0dip"
                android:focusable="true"
                android:scrollbars="vertical"
                android:layout_width="0.0dip"
                android:layout_height="100.0dip"
                android:hint="@string/Profile_Feedback_TextViewHoder_common"
                android:maxLength="600"
                android:layout_alignParentTop="true"
                android:inputType="textMultiLine"
                android:overScrollMode="always"
                android:textCursorDrawable="@drawable/cursor_color"
                android:paddingStart="16.0dip"
                android:paddingEnd="10.0dip"
                android:breakStrategy="simple"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/etFeedbackContent">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/rvAddPic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:textSize="13.0sp"
                    android:textColor="#ff666b75"
                    android:id="@id/tvAddPicTip"
                    android:focusable="false"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:text="@string/ad_setting_about_feedback_img_tip"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12.0dip"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/rvAddPic"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <View
            android:id="@id/view4"
            android:background="@color/ad_base_divider3"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/clFeedbackContent" />
        <com.sand.airdroidkid.common.ui.settings.views.TogglePreferenceV2
            android:id="@id/tpPushService"
            android:background="@android:color/white"
            android:focusable="true"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:layout_marginBottom="8.0dip"
            android:title="@string/ad_setting_about_feedback_log"
            android:layout_marginVertical="8.0dip"
            app:layout_constraintEnd_toStartOf="@id/guidelineEnd"
            app:layout_constraintStart_toStartOf="@id/guidelineStart"
            app:layout_constraintTop_toBottomOf="@id/clFeedbackContent"
            app:showDivider="false"
            app:showSummary="false"
            app:toogleBackground="@drawable/toggle_button" />
        <Button
            android:enabled="false"
            android:textColor="@android:color/white"
            android:id="@id/btSubmit"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="40.0dip"
            android:text="@string/fb_btn_commit"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="@id/rlMail"
            app:layout_constraintStart_toStartOf="@id/rlMail"
            app:layout_constraintTop_toBottomOf="@id/tpPushService"
            app:layout_constraintWidth_max="@dimen/tablet_max_width"
            style="@style/ad_base_activity_btn_padding" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>