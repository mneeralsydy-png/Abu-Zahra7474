<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:gravity="center_vertical"
    android:id="@id/button"
    android:background="@color/black_000000"
    android:visibility="visible"
    android:layout_width="fill_parent"
    android:layout_height="52.0dip"
    android:layout_alignParentBottom="true"
    android:layout_alignParentStart="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <ImageButton
                android:id="@id/bt_exit_ca"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:src="@drawable/ic_quit"
                app:tint="@color/white_ffffff" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <ImageButton
                android:id="@id/bt_rotate_screen_ca"
                android:tag="false"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:src="@drawable/ic_rotate_screen"
                app:tint="@color/white_ffffff" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:id="@id/ll_bt_switch"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <ImageButton
                android:id="@id/bt_switch"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:src="@drawable/ic_rotate_camera"
                android:alpha="1.0"
                app:tint="@color/white_ffffff" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <ImageButton
                android:id="@id/bt_full_screen_ca"
                android:tag="false"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:src="@drawable/ic_full_screen"
                app:tint="@color/white_ffffff" />
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_weight="1.0">
            <ImageButton
                android:id="@id/ibWebRtcCameraMore"
                android:background="@null"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:src="@drawable/more_2_svg"
                app:tint="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>