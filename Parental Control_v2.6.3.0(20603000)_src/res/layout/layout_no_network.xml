<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:gravity="center"
    android:id="@id/root"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/ivNoNetwork"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24.0dip"
        android:src="@drawable/pic_not_network"
        android:contentDescription="@null"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintGuide_percent="0.05" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintGuide_percent="0.95" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/ad_network_fail_msg"
        android:gravity="center"
        android:id="@id/tvHint"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="46.0dip"
        android:text="@string/Network_Error_Retry"
        android:lineSpacingMultiplier="1.2"
        app:layout_constraintBottom_toTopOf="@id/btnReload"
        app:layout_constraintEnd_toEndOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/ivNoNetwork" />
    <Button
        android:textSize="14.0sp"
        android:textColor="@color/text_600"
        android:id="@id/btnReload"
        android:background="@drawable/kid_blue_button_style"
        android:paddingTop="6.0dip"
        android:paddingBottom="6.0dip"
        android:layout_width="196.0dip"
        android:layout_height="44.0dip"
        android:text="@string/main_reload"
        android:paddingStart="30.0dip"
        android:paddingEnd="30.0dip"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHint" />
</androidx.constraintlayout.widget.ConstraintLayout>