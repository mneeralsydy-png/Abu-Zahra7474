<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clRoot"
    android:background="@drawable/ad_base_list_item_bg"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/photoIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingTop="16.0dip"
        android:paddingBottom="16.0dip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:paddingVertical="16.0dip"
        app:layout_constraintEnd_toStartOf="@id/more"
        app:layout_constraintStart_toEndOf="@id/photoIcon"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/gray_464f60"
            android:id="@id/adSettingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preference Title"
            android:layout_marginStart="16.0dip"
            app:layout_constraintBottom_toTopOf="@id/adSettingSubTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/ad_preference_sub_title"
            android:id="@id/adSettingSubTitle"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5.0dip"
            android:text="Preference subTitle"
            app:layout_constraintStart_toStartOf="@id/adSettingTitle"
            app:layout_constraintTop_toBottomOf="@id/adSettingTitle" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/ad_preference_title"
            android:id="@id/adSettingSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preference Summary"
            android:singleLine="true"
            android:layout_marginEnd="4.0dip"
            app:layout_constraintBottom_toBottomOf="@id/adSettingTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/adSettingTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        android:id="@id/more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/more"
        android:layout_marginEnd="10.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@id/divider"
        android:background="@color/ad_base_divider2"
        android:layout_width="0.0dip"
        android:layout_height="1.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>