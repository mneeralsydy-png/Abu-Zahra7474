<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:paddingTop="@dimen/global_horizontal_margin"
    android:paddingBottom="@dimen/global_horizontal_margin"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/global_horizontal_margin"
    android:layout_marginRight="@dimen/global_horizontal_margin"
    android:layout_marginHorizontal="@dimen/global_horizontal_margin"
    android:paddingVertical="@dimen/global_horizontal_margin"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/gray_878d9a"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@id/tvMsg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/update_err_noupdateinfo" />
    <ProgressBar
        android:layout_gravity="center"
        android:id="@id/progressBar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        style="?android:progressBarStyle" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/gray_666b75"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/tvRetry"
        android:background="@drawable/kid_network_failed_bg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="44.0dip"
        android:layout_marginTop="22.0dip"
        android:minWidth="196.0dip"
        android:text="@string/ad_share_retry" />
</LinearLayout>