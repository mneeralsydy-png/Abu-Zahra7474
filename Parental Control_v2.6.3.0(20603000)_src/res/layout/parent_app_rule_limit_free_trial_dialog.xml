<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="@drawable/parent_bind_code_dlg_bg"
    android:paddingBottom="20.0dip"
    android:layout_width="@dimen/dialog_max_width"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:layout_gravity="end"
        android:id="@id/close"
        android:padding="12.0dip"
        android:layout_width="42.0dip"
        android:layout_height="42.0dip"
        android:layout_marginTop="2.0dip"
        android:src="@drawable/ic_close_rating"
        android:contentDescription="@string/Common_close"
        android:layout_marginEnd="2.0dip" />
    <ImageView
        android:textSize="30.0sp"
        android:layout_gravity="center"
        android:layout_width="89.0dip"
        android:layout_height="46.0dip"
        android:src="@drawable/pro_subscription"
        android:contentDescription="@null" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_ff464f60"
        android:gravity="center"
        android:id="@id/feature_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20.0dip"
        android:layout_marginTop="20.0dip"
        android:layout_marginRight="20.0dip"
        android:text="@string/Freemium_Trial_Feature_Description"
        android:lineSpacingMultiplier="1.2"
        android:breakStrategy="simple"
        android:layout_marginHorizontal="20.0dip" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/white_ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/tvSubscribe"
        android:background="@drawable/kid_blue_button_style"
        android:layout_width="fill_parent"
        android:layout_height="44.0dip"
        android:layout_marginLeft="20.0dip"
        android:layout_marginTop="30.0dip"
        android:layout_marginRight="20.0dip"
        android:minWidth="75.0dip"
        android:text="@string/Freemium_Subscribe_Now"
        android:maxLines="1"
        android:layout_marginHorizontal="20.0dip"
        app:fontFamily="@font/font_family_semi_bold" />
</LinearLayout>