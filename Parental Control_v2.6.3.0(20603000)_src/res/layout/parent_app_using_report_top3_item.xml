<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="horizontal"
    android:id="@id/llFirstThreeContent"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/llFirstThreeItem"
        android:background="@drawable/parent_using_report_top3_bg"
        android:paddingLeft="8.0dip"
        android:paddingTop="6.0dip"
        android:paddingRight="8.0dip"
        android:paddingBottom="6.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="8.0dip"
        android:paddingVertical="6.0dip">
        <TextView
            android:textSize="13.0sp"
            android:textColor="#ff6c89e2"
            android:ellipsize="end"
            android:id="@id/tvFirstThreeItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lines="1"
            app:fontFamily="@font/font_family_medium" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/text_100"
            android:ellipsize="end"
            android:id="@id/tvFirstThreeItemDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.0dip"
            android:lines="1"
            app:fontFamily="@font/font_family_semi_bold" />
    </LinearLayout>
</LinearLayout>