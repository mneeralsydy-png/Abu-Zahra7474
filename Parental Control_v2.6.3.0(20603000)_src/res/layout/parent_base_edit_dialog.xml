<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/dialog_radius"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:maxWidth="@dimen/dialog_max_width"
    android:minWidth="@dimen/dialog_max_width"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="20.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="20.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@id/glTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="20.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@id/glBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="6.0dip" />
    <TextView
        android:textSize="18.0sp"
        android:textColor="@color/black_282930"
        android:gravity="center"
        android:id="@id/tvTitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:text="@string/Parent_Safe_Browser_Manage_Rule_Enter_Title"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constraintEnd_toStartOf="@id/pbLoading"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toTopOf="@id/glTop" />
    <TextView
        android:textColor="@color/permission_tip"
        android:gravity="center"
        android:id="@id/tvMessage"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.0dip"
        android:text="@string/Parent_Safe_Browser_Manage_Rule_Delete_Confirm"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:gravity="center"
        android:id="@id/tvTitle1"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.0dip"
        android:text="@string/Parental_Website_Title"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvMessage" />
    <com.sand.airdroidkid.common.ui.base.NewCleanableEditText
        android:id="@id/etInput"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="12.0dip"
        android:minHeight="48.0dip"
        android:inputType="text"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvTitle1"
        app:textPassword="false" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:gravity="center"
        android:id="@id/tvTitle2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="24.0dip"
        android:text="@string/Common_remark_title"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/etInput" />
    <com.sand.airdroidkid.common.ui.base.NewCleanableEditText
        android:id="@id/etInput2"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="8.0dip"
        android:minHeight="48.0dip"
        android:hint="@string/Parent_Device_Edit_Enter_Note"
        android:inputType="text"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/tvTitle2"
        app:maxChars="100"
        app:textPassword="false" />
    <include
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="30.0dip"
        app:layout_constraintBottom_toTopOf="@id/glBottom"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/etInput2"
        layout="@layout/ad_dlg_bottom_btn_bar2" />
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@id/pbLoading"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        app:indicatorColor="@color/gray_ffcfd4df"
        app:indicatorSize="18.0dip"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toStartOf="@id/glEnd"
        app:layout_constraintTop_toTopOf="@id/glTop"
        app:trackThickness="2.0dip" />
    <androidx.constraintlayout.widget.Group
        android:id="@id/gContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="tvOK,tvCancel,tvTitle" />
</androidx.constraintlayout.widget.ConstraintLayout>