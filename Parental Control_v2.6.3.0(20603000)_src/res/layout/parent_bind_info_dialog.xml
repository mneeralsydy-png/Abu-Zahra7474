<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:gravity="center"
    android:background="@android:color/transparent"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_gravity="center"
        android:background="@drawable/device_fragment_item_bg"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/dialog_horizontal_margin"
        android:layout_marginRight="@dimen/dialog_horizontal_margin"
        android:maxWidth="@dimen/dialog_max_width"
        android:elevation="4.0dip"
        android:layout_marginHorizontal="@dimen/dialog_horizontal_margin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/glContentTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_begin="20.0dip" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glContentStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_begin="20.0dip" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glContentEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_end="20.0dip" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/glContentBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_end="20.0dip" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glExitEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_end="16.0dip" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="horizontal"
            android:id="@id/glExitTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_begin="16.0dip" />
        <ImageView
            android:id="@id/ivKidIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/pic_open_kidlogo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/glContentTop" />
        <ImageView
            android:id="@id/ivExit"
            android:layout_width="20.0dip"
            android:layout_height="20.0dip"
            android:src="@drawable/pop_ic_close"
            android:scaleType="center"
            app:layout_constraintEnd_toStartOf="@id/glExitEnd"
            app:layout_constraintTop_toBottomOf="@id/glExitTop" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_ff464f60"
            android:id="@id/tvContent1"
            android:paddingLeft="5.0dip"
            android:paddingRight="5.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dip"
            android:text="@string/Parent_Bind_Step2_Download_Title"
            android:paddingHorizontal="5.0dip"
            app:layout_constraintEnd_toStartOf="@id/glContentEnd"
            app:layout_constraintStart_toEndOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/ivKidIcon" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_ff464f60"
            android:id="@id/tvContent2"
            android:paddingLeft="5.0dip"
            android:paddingRight="5.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="12.0dip"
            android:text="@string/Parent_Bind_Step2_Download_Text"
            android:paddingHorizontal="5.0dip"
            app:layout_constraintEnd_toStartOf="@id/glContentEnd"
            app:layout_constraintStart_toEndOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/tvContent1" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@id/llDownload"
            android:background="@drawable/parent_download_url_bg"
            android:paddingTop="9.0dip"
            android:paddingBottom="9.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20.0dip"
            android:paddingStart="16.0dip"
            android:paddingEnd="16.0dip"
            app:layout_constraintBottom_toTopOf="@id/glContentBottom"
            app:layout_constraintEnd_toStartOf="@id/glContentEnd"
            app:layout_constraintStart_toEndOf="@id/glContentStart"
            app:layout_constraintTop_toBottomOf="@id/tvContent2">
            <TextView
                android:textSize="16.0sp"
                android:textColor="@color/blue_446efc"
                android:gravity="center"
                android:id="@id/tvDownloadUrl"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:text="@string/common_loading"
                android:layout_weight="1.0"
                android:breakStrategy="simple"
                app:layout_constraintEnd_toStartOf="@id/ivRefreshDownloadUrl"
                app:layout_constraintHorizontal_weight="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <ImageView
                android:id="@id/ivRefreshDownloadUrl"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10.0dip"
                app:layout_constraintBottom_toBottomOf="@id/tvDownloadUrl"
                app:layout_constraintEnd_toStartOf="@id/ivDownloadShare"
                app:layout_constraintStart_toEndOf="@id/tvDownloadUrl"
                app:layout_constraintTop_toTopOf="@id/tvDownloadUrl"
                app:srcCompat="@drawable/ic_refresh" />
            <ImageView
                android:id="@id/ivDownloadShare"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10.0dip"
                app:layout_constraintBottom_toBottomOf="@id/tvDownloadUrl"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivRefreshDownloadUrl"
                app:layout_constraintTop_toTopOf="@id/tvDownloadUrl"
                app:srcCompat="@drawable/ic_share" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>