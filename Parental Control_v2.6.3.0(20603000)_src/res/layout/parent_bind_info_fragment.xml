<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/ivMenu"
        android:padding="8.0dip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="13.0dip"
        android:contentDescription="@null"
        android:layout_marginEnd="13.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_more_2" />
    <View
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@id/viewJoinFamilyRemind"
        android:background="@drawable/red_e13e3e_radius"
        android:visibility="gone"
        android:layout_width="8.0dip"
        android:layout_height="8.0dip"
        android:layout_marginTop="16.0dip"
        android:contentDescription="@null"
        android:layout_marginEnd="20.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ScrollView
        android:id="@id/scroll_view"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginBottom="30.0dip"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/button_barrier"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivMenu"
        app:layout_constraintWidth_max="@dimen/tablet_max_width">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@android:color/white"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.Guideline
                android:orientation="horizontal"
                android:id="@id/glTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/bind_fragment_top_percent" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_begin="20.0dip" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_end="20.0dip" />
            <ImageView
                android:id="@id/ivTopImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30.0dip"
                android:src="@drawable/pic_bind"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:gravity="center_horizontal"
                android:id="@id/tvTitle"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip"
                android:text="@string/Parent_Bind_Step2_Title"
                app:layout_constraintEnd_toStartOf="@id/glEnd"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toBottomOf="@id/ivTopImage"
                style="@style/binding_page_title" />
            <RelativeLayout
                android:id="@id/rlQrBlock"
                android:background="@drawable/parent_download_url_bg"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="20.0dip"
                app:layout_constraintEnd_toEndOf="@id/glEnd"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toBottomOf="@id/tvTitle">
                <TextView
                    android:textSize="14.0sp"
                    android:textColor="@color/black_464F60"
                    android:gravity="center_horizontal"
                    android:id="@id/scanCodeMsg"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16.0dip"
                    android:layout_marginTop="16.0dip"
                    android:layout_marginRight="16.0dip"
                    android:text="@string/binding_step1"
                    android:layout_marginHorizontal="16.0dip" />
                <RelativeLayout
                    android:id="@id/rlQrBox"
                    android:background="@drawable/bg_radius_8_white"
                    android:layout_width="164.0dip"
                    android:layout_height="164.0dip"
                    android:layout_marginTop="10.0dip"
                    android:layout_below="@id/scanCodeMsg"
                    android:layout_centerHorizontal="true">
                    <ImageView
                        android:id="@id/ivQrImage"
                        android:layout_width="140.0dip"
                        android:layout_height="140.0dip"
                        android:layout_centerInParent="true" />
                </RelativeLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:orientation="horizontal"
                    android:id="@id/url_block"
                    android:paddingBottom="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16.0dip"
                    android:layout_marginTop="12.0dip"
                    android:layout_marginRight="16.0dip"
                    android:layout_below="@id/rlQrBox"
                    android:layout_centerHorizontal="true"
                    android:layout_marginHorizontal="16.0dip">
                    <TextView
                        android:textSize="18.0sp"
                        android:textColor="@color/blue_446efc"
                        android:id="@id/tvDownloadUrl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Parent_Bind_Step2_ViewUrl"
                        app:fontFamily="@font/font_family_semi_bold"
                        app:layout_constrainedWidth="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivOpenUrlShare"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@id/ivOpenUrlShare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null"
                        android:layout_marginStart="6.0dip"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvDownloadUrl"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/grey_share" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <TextView
                    android:textSize="14.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue_446efc"
                    android:id="@id/tvLinkLoading"
                    android:paddingBottom="16.0dip"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:text="@string/common_loading"
                    android:layout_below="@id/rlQrBox"
                    android:layout_centerHorizontal="true"
                    app:fontFamily="@font/font_family_medium" />
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@id/link_fail_block"
                    android:paddingBottom="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:layout_below="@id/rlQrBox"
                    android:layout_centerHorizontal="true">
                    <TextView
                        android:textSize="14.0sp"
                        android:textStyle="bold"
                        android:textColor="@color/blue_446efc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Parent_Position_Retry"
                        app:fontFamily="@font/font_family_semi_bold" />
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@id/ivRefreshLink"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null"
                        android:layout_marginStart="6.0dip"
                        app:srcCompat="@drawable/blue_refresh_svg" />
                </LinearLayout>
            </RelativeLayout>
            <TextView
                android:textSize="13.0sp"
                android:textColor="@color/blue_446efc"
                android:id="@id/tvBindStatusCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip"
                android:text="@string/Parent_Bind_Step_Has_Device"
                app:layout_constraintEnd_toEndOf="@id/glEnd"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toBottomOf="@id/rlCodeBlock" />
            <RelativeLayout
                android:id="@id/rlCodeBlock"
                android:background="@drawable/parent_download_url_bg"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="20.0dip"
                app:layout_constraintEnd_toEndOf="@id/glEnd"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toBottomOf="@id/rlQrBlock">
                <TextView
                    android:textSize="14.0sp"
                    android:textColor="@color/black_464F60"
                    android:gravity="center_horizontal"
                    android:id="@id/tvCodeMsg"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16.0dip"
                    android:layout_marginTop="16.0dip"
                    android:layout_marginRight="16.0dip"
                    android:text="@string/binding_step2"
                    android:layout_marginHorizontal="16.0dip" />
                <TextView
                    android:textSize="26.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/black_282930"
                    android:gravity="center_horizontal"
                    android:id="@id/tvBindCode"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:text="@string/Parent_Bind_Step2_Requesting_Code"
                    android:layout_below="@id/tvCodeMsg"
                    android:layout_centerHorizontal="true"
                    android:textDirection="ltr"
                    app:fontFamily="@font/font_family_semi_bold" />
                <TextView
                    android:textSize="14.0sp"
                    android:textColor="@color/gray_878d9a"
                    android:gravity="center_horizontal"
                    android:id="@id/tvBindCodeTip"
                    android:paddingBottom="16.0dip"
                    android:visibility="invisible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:text="@string/Binding_Code_Valid"
                    android:layout_below="@id/tvBindCode"
                    android:layout_centerHorizontal="true" />
                <TextView
                    android:textSize="14.0sp"
                    android:textStyle="bold"
                    android:textColor="@color/blue_446efc"
                    android:id="@id/tvBindCodeLoading"
                    android:paddingBottom="16.0dip"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:text="@string/common_loading"
                    android:layout_below="@id/tvCodeMsg"
                    android:layout_centerHorizontal="true"
                    app:fontFamily="@font/font_family_medium" />
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@id/bind_code_fail_block"
                    android:paddingBottom="16.0dip"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:layout_below="@id/tvCodeMsg"
                    android:layout_centerHorizontal="true">
                    <TextView
                        android:textSize="14.0sp"
                        android:textStyle="bold"
                        android:textColor="@color/blue_446efc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Parent_Position_Retry"
                        app:fontFamily="@font/font_family_medium" />
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@id/ivRefreshCode"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@null"
                        android:layout_marginStart="6.0dip"
                        app:srcCompat="@drawable/blue_refresh_svg" />
                </LinearLayout>
            </RelativeLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_end="20.0dip" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_begin="20.0dip" />
    <androidx.constraintlayout.widget.Barrier
        android:id="@id/button_barrier"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:barrierDirection="top"
        app:constraint_referenced_ids="tvSkip,tvDone" />
    <TextView
        android:textSize="14.0sp"
        android:id="@id/tvSkip"
        android:layout_marginBottom="30.0dip"
        android:text="@string/Parent_No_Continue_Title"
        android:layout_marginStart="20.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/glEnd2"
        app:layout_constraintVertical_bias="1.0"
        style="@style/parent_blue_btn" />
    <TextView
        android:textSize="16.0sp"
        android:textStyle="bold"
        android:textColor="@color/color_white"
        android:gravity="center"
        android:id="@id/tvDone"
        android:background="@drawable/kid_blue_button_style"
        android:paddingLeft="20.0dip"
        android:paddingTop="10.0dip"
        android:paddingRight="20.0dip"
        android:paddingBottom="10.0dip"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30.0dip"
        android:minWidth="110.0dip"
        android:text="@string/Common_Complete"
        android:paddingHorizontal="20.0dip"
        android:paddingVertical="10.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/glEnd2"
        app:layout_constraintVertical_bias="1.0" />
</androidx.constraintlayout.widget.ConstraintLayout>