<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clRoot"
    android:background="@color/white_f5f5f5"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@id/toolbar"
        android:background="@color/white_f5f5f5"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        android:minHeight="?actionBarSize"
        android:layout_marginEnd="10.0dip"
        android:elevation="0.0dip"
        app:contentInsetStartWithNavigation="0.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:menu="@menu/parent_content_detection_keyword_manage_menu"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/Parent_Keyword_Manage_Add"
        app:titleMargin="0.0dip"
        app:titleTextAppearance="@style/CommonAppTheme.ToolBarTitleTextAppearance"
        app:titleTextColor="@color/black_282930" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="@dimen/global_start_percent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="@dimen/global_end_percent" />
    <androidx.core.widget.NestedScrollView
        android:scrollbars="none"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        android:layout_marginTop="10.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/glEnd"
        app:layout_constraintStart_toStartOf="@id/glStart"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/clClassifyRoot"
                android:background="@drawable/usage_limit_bg"
                android:paddingLeft="16.0dip"
                android:paddingTop="12.0dip"
                android:paddingRight="16.0dip"
                android:paddingBottom="12.0dip"
                android:layout_width="fill_parent"
                android:layout_height="54.0dip"
                android:paddingHorizontal="16.0dip"
                android:paddingVertical="12.0dip"
                app:layout_constraintBottom_toTopOf="@id/tvKeywordManageListTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:textSize="15.0sp"
                    android:textColor="@color/black_282930"
                    android:id="@id/tvClassifyNameTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/Parent_Keyword_Manage_Category"
                    app:fontFamily="@font/font_family_medium"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/etClassifyName"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <EditText
                    android:textSize="14.0sp"
                    android:textColor="@color/black_ff464f60"
                    android:textColorHint="@color/gray_ff878d9a"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:id="@id/etClassifyName"
                    android:background="@null"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10.0dip"
                    android:layout_marginRight="10.0dip"
                    android:hint="@string/Parent_Keyword_Manage_Placeholder"
                    android:lines="1"
                    android:maxLength="200"
                    android:inputType="text"
                    android:layout_marginHorizontal="10.0dip"
                    app:fontFamily="@font/font_family_medium"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvClassifyNameTitle"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:id="@id/tvKeywordManageListTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20.0dip"
                android:text="@string/Parent_Keyword_Manage"
                android:layout_marginStart="16.0dip"
                app:layout_constraintBottom_toTopOf="@id/clKeywordManageListRoot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clClassifyRoot" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/clKeywordManageListRoot"
                android:background="@drawable/usage_limit_bg"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip"
                android:layout_marginBottom="20.0dip"
                app:layout_constraintBottom_toTopOf="@id/tvDeleteKeywordGroup"
                app:layout_constraintTop_toBottomOf="@id/tvKeywordManageListTitle">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@id/clAddKeywordRoot"
                    android:paddingLeft="16.0dip"
                    android:paddingRight="16.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16.0dip"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <TextView
                        android:textSize="14.0sp"
                        android:textColor="@color/black_ff282930"
                        android:ellipsize="end"
                        android:id="@id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16.0dip"
                        android:layout_marginBottom="16.0dip"
                        android:text="@string/Parent_Keyword_Manage_Placeholder1"
                        android:maxLines="1"
                        android:layout_marginEnd="20.0dip"
                        android:layout_marginVertical="16.0dip"
                        app:fontFamily="@font/font_family_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:maxChars="50" />
                    <ImageView
                        android:id="@id/ivAdd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/add"
                        android:contentDescription="@null"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <ImageView
                    android:id="@id/ivNoKeyword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12.0dip"
                    android:src="@drawable/pic_not_add"
                    android:contentDescription="@string/Parent_Keyword_Placeholder"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clAddKeywordRoot" />
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="@color/gray_ff878d9a"
                    android:gravity="center_horizontal"
                    android:id="@id/tvNoKeyword"
                    android:paddingBottom="30.0dip"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20.0dip"
                    android:text="@string/Parent_Keyword_Placeholder"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivNoKeyword" />
                <View
                    android:id="@id/divider"
                    android:background="@color/white_f5f5f5"
                    android:layout_width="fill_parent"
                    android:layout_height="1.0dip"
                    app:layout_constraintTop_toBottomOf="@id/clAddKeywordRoot" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/rvDetectedKeywordList"
                    android:paddingLeft="16.0dip"
                    android:paddingRight="16.0dip"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16.0dip"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/red_e13e3e"
                android:gravity="center"
                android:id="@id/tvDeleteKeywordGroup"
                android:background="@drawable/item_bg200_radius16_click_background"
                android:paddingTop="12.0dip"
                android:paddingBottom="12.0dip"
                android:layout_width="fill_parent"
                android:layout_height="54.0dip"
                android:layout_marginBottom="20.0dip"
                android:text="@string/Parent_Keyword_Manage_Delete"
                android:paddingVertical="12.0dip"
                app:fontFamily="@font/font_family_medium"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>