<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clRoot"
    android:background="@color/white_ffffff"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@id/toolbar"
        android:background="@color/white_ffffff"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        android:minHeight="?actionBarSize"
        android:elevation="0.0dip"
        app:contentInsetStartWithNavigation="0.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/Parent_Keyword_Manage"
        app:titleMargin="0.0dip"
        app:titleTextAppearance="@style/CommonAppTheme.ToolBarTitleTextAppearance"
        app:titleTextColor="@color/black_282930" />
    <RadioGroup
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@id/rgAddContentKeyword"
        android:background="@drawable/switch_group_background"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30.0dip"
        android:layout_marginTop="10.0dip"
        android:layout_marginRight="30.0dip"
        android:layout_marginBottom="10.0dip"
        android:layout_marginHorizontal="30.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <RadioButton
            android:textStyle="bold"
            android:textColor="@drawable/parent_today_event_item_text_color_selector"
            android:gravity="center"
            android:id="@id/rbAddKeywordCustom"
            android:background="@drawable/switch_button_background"
            android:paddingLeft="16.0dip"
            android:paddingTop="4.0dip"
            android:paddingRight="16.0dip"
            android:paddingBottom="4.0dip"
            android:checked="true"
            android:button="@drawable/switch_button_background"
            android:text="@string/Parent_UsageLimit_EveryDay_Custom_Period"
            android:paddingHorizontal="16.0dip"
            android:paddingVertical="4.0dip"
            style="@style/switch_button_style" />
        <RadioButton
            android:textColor="@drawable/parent_today_event_item_text_color_selector"
            android:gravity="center"
            android:id="@id/rbAddKeywordSubscribe"
            android:background="@drawable/switch_button_background"
            android:paddingLeft="16.0dip"
            android:paddingTop="4.0dip"
            android:paddingRight="16.0dip"
            android:paddingBottom="4.0dip"
            android:checked="false"
            android:button="@drawable/switch_button_background"
            android:text="@string/parent_browser_tab_subscribe"
            android:paddingHorizontal="16.0dip"
            android:paddingVertical="4.0dip"
            style="@style/switch_button_style" />
    </RadioGroup>
    <androidx.fragment.app.FragmentContainerView
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:id="@id/nav_host_fragment"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="10.0dip"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rgAddContentKeyword"
        app:navGraph="@navigation/content_detection_keyword_manage_navigation" />
</androidx.constraintlayout.widget.ConstraintLayout>