<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <View
        android:id="@id/vDeviceListDivider"
        android:background="@color/gray_ececee"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.recyclerview.widget.RecyclerView
        android:scrollbarSize="4.0dip"
        android:scrollbarThumbVertical="@drawable/custom_scrollbar"
        android:scrollbarStyle="outsideOverlay"
        android:id="@id/rvDeviceBoundList"
        android:background="@color/white_ffffff"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:fadeScrollbars="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vDeviceListDivider" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clAddDeviceItem"
        android:background="@drawable/white_bottom_radius"
        android:focusable="true"
        android:visibility="gone"
        android:clickable="true"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rvDeviceBoundList">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glAddDeviceStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_start_percent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glAddDeviceEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_end_percent" />
        <View
            android:id="@id/vAddDeviceDivider"
            android:background="@color/gray_ececee"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            app:layout_constraintEnd_toEndOf="@id/glAddDeviceEnd"
            app:layout_constraintStart_toStartOf="@id/glAddDeviceStart"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:id="@id/ivAddDeviceIcon"
            android:background="@drawable/background_color_circle_selector"
            android:layout_width="34.0dip"
            android:layout_height="34.0dip"
            android:layout_marginTop="16.0dip"
            android:layout_marginBottom="16.0dip"
            android:src="@drawable/add_line"
            android:scaleType="centerInside"
            android:contentDescription="@null"
            android:backgroundTint="@color/gray_e8eaee"
            android:layout_marginVertical="16.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/glAddDeviceStart"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@android:color/black"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@id/tvAddDeviceText"
            android:layout_width="0.0dip"
            android:layout_height="22.0dip"
            android:text="@string/parental_add_device"
            android:maxLines="1"
            android:textAlignment="viewStart"
            android:layout_marginStart="12.0dip"
            app:fontFamily="@font/font_family_medium"
            app:layout_constraintBottom_toBottomOf="@id/ivAddDeviceIcon"
            app:layout_constraintEnd_toEndOf="@id/glAddDeviceEnd"
            app:layout_constraintStart_toEndOf="@id/ivAddDeviceIcon"
            app:layout_constraintTop_toTopOf="@id/ivAddDeviceIcon" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>