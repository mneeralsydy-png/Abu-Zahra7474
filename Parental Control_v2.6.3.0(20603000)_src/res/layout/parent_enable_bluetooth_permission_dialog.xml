<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_gravity="center"
    android:background="@drawable/dialog_radius"
    android:paddingLeft="20.0dip"
    android:paddingTop="20.0dip"
    android:paddingRight="20.0dip"
    android:paddingBottom="6.0dip"
    android:layout_width="@dimen/dialog_max_width"
    android:layout_height="wrap_content"
    android:paddingHorizontal="20.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/ivBlueToothIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/pic_sound_bluetooth"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_282930"
        android:gravity="center"
        android:id="@id/tvMessage"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12.0dip"
        android:text="@string/parent_enable_bluetooth_message"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBlueToothIcon" />
    <CheckBox
        android:id="@id/cbTrustDevice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14.0dip"
        android:button="@drawable/selector_parent_checkbox_blue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMessage" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="#ff878d9b"
        android:id="@id/tvTrustTip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:text="@string/Parent_No_prompt"
        android:layout_marginStart="11.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cbTrustDevice"
        app:layout_constraintTop_toTopOf="@id/cbTrustDevice" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/llBtnPane"
        android:visibility="visible"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginTop="30.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTrustTip">
        <TextView
            android:textSize="14.0sp"
            android:textColor="#ffa4a8b3"
            android:id="@id/tvCancel"
            android:background="@drawable/ad_dlg_btn_color_bg"
            android:focusable="true"
            android:layout_width="0.0dip"
            android:layout_marginTop="6.0dip"
            android:text="@string/ad_cancel"
            app:fontFamily="@font/font_family_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOK"
            style="@style/ad_dlg_base_btn_padding" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@color/white_ffffff"
            android:id="@id/tvOK"
            android:background="@drawable/kid_blue_button_style"
            android:focusable="true"
            android:layout_width="0.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/ad_dlg_base_btn_padding" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>