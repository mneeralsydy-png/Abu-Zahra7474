<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    android:id="@id/clRoot"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@android:color/white"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <include
            android:id="@id/appBar"
            layout="@layout/app_bar_no_title" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/appBar"
            app:layout_constraintWidth_max="@dimen/tablet_max_width">
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.05" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.95" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="horizontal"
                android:id="@id/glButtom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_end="32.0dip" />
            <TextView
                android:textSize="22.0sp"
                android:textColor="@color/black_282930"
                android:id="@id/tvTitle"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="10.0dip"
                android:text="@string/ad_setting_account_change_pw_forget"
                app:fontFamily="@font/font_family_semi_bold"
                app:layout_constraintEnd_toStartOf="@id/glRight"
                app:layout_constraintStart_toStartOf="@id/glLeft"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:textSize="13.0sp"
                android:textColor="@color/gray_666b75"
                android:id="@id/tvContent"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="6.0dip"
                android:text="@string/Account_Reset_Text"
                android:breakStrategy="simple"
                app:layout_constraintEnd_toStartOf="@id/glRight"
                app:layout_constraintStart_toStartOf="@id/glLeft"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />
            <TextView
                android:textSize="14.0sp"
                android:textStyle="bold"
                android:textColor="@color/color_main_text"
                android:id="@id/tvEmailTitle"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="30.0dip"
                android:text="@string/Parent_Email_Title"
                android:layout_marginStart="4.0dip"
                app:layout_constraintEnd_toStartOf="@id/glRight"
                app:layout_constraintStart_toStartOf="@id/glLeft"
                app:layout_constraintTop_toBottomOf="@id/tvContent" />
            <com.sand.airdroidkid.common.ui.base.NewCleanableEditText
                android:id="@id/etEmail"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4.0dip"
                android:layout_marginTop="8.0dip"
                android:layout_marginRight="4.0dip"
                android:hint="@string/Profile_Feedback_EnterEmail"
                android:layout_marginHorizontal="4.0dip"
                app:layout_constraintEnd_toStartOf="@id/glRight"
                app:layout_constraintStart_toStartOf="@id/glLeft"
                app:layout_constraintTop_toBottomOf="@id/tvEmailTitle"
                app:textPassword="false" />
            <TextView
                android:textSize="16.0sp"
                android:textColor="@android:color/white"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@id/tvSendReset"
                android:background="@drawable/kid_blue_button_style"
                android:padding="10.0dip"
                android:layout_width="0.0dip"
                android:layout_height="40.0dip"
                android:layout_marginTop="40.0dip"
                android:text="@string/fp_btn_reset"
                android:maxLines="1"
                app:fontFamily="@font/font_family_semi_bold"
                app:layout_constraintEnd_toEndOf="@id/glRight"
                app:layout_constraintStart_toStartOf="@id/glLeft"
                app:layout_constraintTop_toBottomOf="@id/etEmail" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>