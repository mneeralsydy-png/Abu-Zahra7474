<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/parent_menu_bg"
    android:paddingBottom="4.0dip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:maxWidth="260.0dip"
    android:minWidth="140.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clAccountInfo"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@id/ivAccountAvatar"
            android:layout_width="36.0dip"
            android:layout_height="36.0dip"
            android:layout_marginTop="16.0dip"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@color/black_282930"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvAccountNickName"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:maxWidth="228.0dip"
            android:maxLines="1"
            android:layout_marginStart="16.0dip"
            android:layout_marginEnd="16.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivAccountAvatar" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/gray_878d9a"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvAccountMail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.0dip"
            android:maxWidth="228.0dip"
            android:lines="1"
            android:layout_marginStart="16.0dip"
            android:layout_marginEnd="16.0dip"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAccountNickName" />
        <View
            android:id="@id/dividerAccount"
            android:background="@color/menu_divider"
            android:layout_width="0.0dip"
            android:layout_height="1.0dip"
            android:layout_marginTop="14.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAccountMail" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/liFeedback"
        android:paddingBottom="8.0dip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginRight="16.0dip"
        android:layout_marginHorizontal="16.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clAccountInfo"
        app:layout_constraintWidth_default="wrap">
        <ImageView
            android:id="@id/ivFeedback"
            android:layout_width="20.0dip"
            android:layout_height="20.0dip"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_feedback_svg" />
        <TextView
            android:layout_gravity="center_vertical"
            android:id="@id/tvFeedbackTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Setting_Feedback"
            style="@style/parent_menu_pop_window_text" />
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clJoinFamily"
        android:paddingBottom="8.0dip"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginRight="16.0dip"
        android:layout_marginHorizontal="16.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/liFeedback"
        app:layout_constraintWidth_default="wrap">
        <ImageView
            android:id="@id/ivJoinFamily"
            android:layout_width="20.0dip"
            android:layout_height="20.0dip"
            android:contentDescription="@null"
            android:layout_marginEnd="8.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/family" />
        <TextView
            android:layout_gravity="center_vertical"
            android:id="@id/tvJoinFamilyTitle"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Join_Family"
            android:layout_marginEnd="5.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/viewJoinFamilyRemind"
            app:layout_constraintStart_toEndOf="@id/ivJoinFamily"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_default="wrap"
            app:layout_goneMarginEnd="0.0dip"
            style="@style/parent_menu_pop_window_text" />
        <View
            android:id="@id/viewJoinFamilyRemind"
            android:background="@drawable/red_e13e3e_radius"
            android:visibility="gone"
            android:layout_width="8.0dip"
            android:layout_height="8.0dip"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="@id/tvJoinFamilyTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvJoinFamilyTitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/liAbout"
        android:paddingBottom="8.0dip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginRight="16.0dip"
        android:layout_marginHorizontal="16.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clJoinFamily"
        app:layout_constraintWidth_default="wrap">
        <ImageView
            android:id="@id/ivAbout"
            android:layout_width="20.0dip"
            android:layout_height="20.0dip"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_about_svg" />
        <TextView
            android:layout_gravity="center_vertical"
            android:id="@id/tvAboutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Setting_About"
            style="@style/parent_menu_pop_window_text" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/liLogout"
        android:paddingBottom="8.0dip"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_marginRight="16.0dip"
        android:layout_marginHorizontal="16.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/liAbout"
        app:layout_constraintWidth_default="wrap">
        <ImageView
            android:id="@id/ivLogout"
            android:layout_width="20.0dip"
            android:layout_height="20.0dip"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_logout_svg" />
        <TextView
            android:layout_gravity="center_vertical"
            android:id="@id/tvLogoutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Profile_Logout_Title"
            style="@style/parent_menu_pop_window_text" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>