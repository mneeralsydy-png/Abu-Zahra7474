<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clRoot"
    android:background="@color/white_fff5f5f5"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.appbar.MaterialToolbar
        android:theme="@style/ToolBarStyle"
        android:id="@id/toolbar"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        android:minHeight="?actionBarSize"
        android:elevation="0.0dip"
        app:contentInsetStartWithNavigation="0.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/Parent_UsageLimit_Forbid_New_Title"
        app:titleMargin="0.0dip"
        app:titleTextAppearance="@style/CommonAppTheme.ToolBarTitleTextAppearance"
        app:titleTextColor="@color/black_282930" />
    <androidx.core.widget.NestedScrollView
        android:scrollbars="none"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:fillViewport="true"
        app:layout_constrainedHeight="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:paddingBottom="20.0dip"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/global_start_percent" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/global_end_percent" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/glEnd"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toTopOf="parent">
                <RadioGroup
                    android:id="@id/rgNewAppLimit"
                    android:background="@drawable/bg_radius_16_stroke_1"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.0dip"
                    android:divider="@drawable/radio_group_divider"
                    android:showDividers="middle"
                    android:paddingStart="16.0dip"
                    android:paddingEnd="16.0dip"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <RadioButton
                        android:textSize="15.0sp"
                        android:textColor="@color/black_282930"
                        android:id="@id/rbAllow"
                        android:background="@color/ad_transparent"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6.0dip"
                        android:layout_marginBottom="6.0dip"
                        android:checked="true"
                        android:button="@null"
                        android:text="@string/Parent_Device_Alert_Allow"
                        android:drawableEnd="@drawable/select_app_box_style"
                        android:layout_marginVertical="6.0dip"
                        app:fontFamily="@font/font_family_medium" />
                    <RadioButton
                        android:textSize="15.0sp"
                        android:textColor="@color/black_282930"
                        android:id="@id/rbDisallow"
                        android:background="@color/ad_transparent"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6.0dip"
                        android:layout_marginBottom="6.0dip"
                        android:button="@null"
                        android:text="@string/kid_restrictions_common_disallow"
                        android:drawableEnd="@drawable/select_app_box_style"
                        android:layout_marginVertical="6.0dip"
                        app:fontFamily="@font/font_family_medium" />
                </RadioGroup>
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="@color/gray_878d9a"
                    android:id="@id/tvNewAppLimitHint"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8.0dip"
                    android:text="@string/Parent_UsageLimit_Forbid_New_Text"
                    android:layout_marginStart="16.0dip"
                    android:layout_marginEnd="16.0dip"
                    app:layout_constraintEnd_toEndOf="@id/rgNewAppLimit"
                    app:layout_constraintStart_toStartOf="@id/rgNewAppLimit"
                    app:layout_constraintTop_toBottomOf="@id/rgNewAppLimit" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>