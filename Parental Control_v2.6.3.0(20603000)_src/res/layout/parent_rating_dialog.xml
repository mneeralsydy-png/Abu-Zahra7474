<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:gravity="center_horizontal"
    android:id="@id/layoutDialog"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/bg_radius_16"
        android:layout_width="300.0dip"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@id/ivRatingBackground"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/pic_score"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:id="@id/ivRatingClose"
            android:padding="8.0dip"
            android:layout_width="30.0dip"
            android:layout_height="30.0dip"
            android:layout_marginTop="6.0dip"
            android:src="@drawable/ic_close_rating"
            android:layout_marginEnd="6.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@color/black_ff282930"
            android:gravity="center"
            android:id="@id/tvTitle"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="5.0dip"
            android:layout_marginStart="26.0dip"
            android:layout_marginEnd="26.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivRatingBackground" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/parent_rating_bad"
            android:id="@id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5.0dip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />
        <RatingBar
            android:id="@id/rbGiveStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            android:numStars="5"
            android:rating="0.0"
            android:stepSize="1.0"
            app:layout_constrainedHeight="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLevel"
            style="@style/parent_rating_bar" />
        <TextView
            android:enabled="false"
            android:textSize="16.0sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvGiveRating"
            android:background="@drawable/kid_blue_button_style"
            android:paddingLeft="20.0dip"
            android:paddingRight="20.0dip"
            android:layout_width="0.0dip"
            android:layout_height="40.0dip"
            android:layout_marginTop="20.0dip"
            android:layout_marginBottom="22.0dip"
            android:text="@string/user_rate_feedback"
            android:maxLines="1"
            android:layout_marginStart="22.0dip"
            android:layout_marginEnd="22.0dip"
            android:paddingHorizontal="20.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rbGiveStar" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>