<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/parent_download_url_bg"
    android:paddingLeft="16.0dip"
    android:paddingTop="16.0dip"
    android:paddingRight="16.0dip"
    android:paddingBottom="16.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16.0dip"
    android:paddingVertical="16.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/gray_464f60"
        android:gravity="center"
        android:id="@id/tvDownloadTitle"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12.0dip"
        android:text="@string/Parent_Safe_Browser_Get_Step1"
        app:layout_constraintBottom_toTopOf="@id/flQRCode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <FrameLayout
        android:id="@id/flQRCode"
        android:background="@drawable/bg_radius_8_white"
        android:layout_width="164.0dip"
        android:layout_height="164.0dip"
        android:layout_marginBottom="11.0dip"
        app:layout_constraintBottom_toTopOf="@id/clDownloadUrl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:id="@id/ivQRCode"
            android:layout_width="140.0dip"
            android:layout_height="140.0dip"
            android:contentDescription="@null" />
    </FrameLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center"
        android:id="@id/clDownloadUrl"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <TextView
            android:textSize="18.0sp"
            android:textStyle="bold"
            android:textColor="@color/blue_446efc"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@id/tvDownloadUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Parent_Bind_Step2_ViewUrl"
            android:layout_marginEnd="11.0dip"
            app:layout_constrainedWidth="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivBrowserUrlShare"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:layout_gravity="center"
            android:id="@id/ivBrowserUrlShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="@id/tvDownloadUrl"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvDownloadUrl"
            app:layout_constraintTop_toTopOf="@id/tvDownloadUrl"
            app:srcCompat="@drawable/grey_share_svg" />
        <ImageView
            android:layout_gravity="center"
            android:id="@id/ivRefreshDownloadUrl"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvDownloadUrl"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_refresh" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>