<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/clRoot"
    android:background="@color/white_fff5f5f5"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@id/toolbar"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        android:minHeight="?actionBarSize"
        android:elevation="0.0dip"
        app:contentInsetStartWithNavigation="0.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/Parent_Safe_Browser_Manage_History_Label"
        app:titleMargin="0.0dip"
        app:titleTextAppearance="@style/CommonAppTheme.ToolBarTitleTextAppearance"
        app:titleTextColor="@color/black_282930" />
    <androidx.core.widget.NestedScrollView
        android:id="@id/nsvMain"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/flOk"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/global_start_percent" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/global_end_percent" />
            <RadioGroup
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@id/rgEvent"
                android:background="@drawable/switch_group_background"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10.0dip"
                android:layout_marginTop="10.0dip"
                android:layout_marginRight="10.0dip"
                android:layout_marginHorizontal="10.0dip"
                app:layout_constraintEnd_toEndOf="@id/glEnd"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toTopOf="parent">
                <RadioButton
                    android:textSize="15.0sp"
                    android:textColor="@drawable/parent_today_event_item_text_color_selector"
                    android:gravity="center"
                    android:id="@id/rbAllEvent"
                    android:background="@drawable/switch_button_background"
                    android:paddingLeft="16.0dip"
                    android:paddingTop="4.0dip"
                    android:paddingRight="16.0dip"
                    android:paddingBottom="4.0dip"
                    android:checked="true"
                    android:button="@drawable/switch_button_background"
                    android:text="@string/Parent_Safe_Browser_Manage_History_Filter_All"
                    android:paddingHorizontal="16.0dip"
                    android:paddingVertical="4.0dip"
                    app:fontFamily="@font/font_family_semi_bold"
                    style="@style/switch_button_style" />
                <RadioButton
                    android:textSize="15.0sp"
                    android:textColor="@drawable/parent_today_event_item_text_color_selector"
                    android:gravity="center"
                    android:id="@id/rbInterceptedEvent"
                    android:background="@drawable/switch_button_background"
                    android:paddingLeft="16.0dip"
                    android:paddingTop="4.0dip"
                    android:paddingRight="16.0dip"
                    android:paddingBottom="4.0dip"
                    android:checked="false"
                    android:button="@drawable/switch_button_background"
                    android:text="@string/Parent_Safe_Browser_Manage_History_Filter_Intercepted"
                    android:paddingHorizontal="16.0dip"
                    android:paddingVertical="4.0dip"
                    style="@style/switch_button_style" />
            </RadioGroup>
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@id/swipeRefresh"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="8.0dip"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rgEvent">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/rvHistory"
                    android:paddingBottom="80.0dip"
                    android:clipToPadding="false"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
            <include
                android:id="@id/layoutEmptyData"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rgEvent"
                layout="@layout/layout_empty_detection_data" />
            <include
                android:id="@id/layoutNoNetwork"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rgEvent"
                layout="@layout/layout_no_network" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/flOk"
        android:paddingTop="20.0dip"
        android:paddingBottom="30.0dip"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_min="36.0dip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_min="196.0dip">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glOkStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_start_percent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glOkEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_end_percent" />
        <TextView
            android:enabled="false"
            android:textSize="16.0sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvOk"
            android:background="@drawable/kid_blue_button_style"
            android:paddingLeft="40.0dip"
            android:paddingRight="40.0dip"
            android:layout_width="0.0dip"
            android:layout_height="44.0dip"
            android:minWidth="192.0dip"
            android:text="@string/Common_OK"
            android:maxLines="1"
            android:paddingHorizontal="40.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/glOkEnd"
            app:layout_constraintStart_toStartOf="@id/glOkStart"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>