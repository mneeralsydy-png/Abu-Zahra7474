<?xml version="1.0" encoding="utf-8"?>
<com.sand.airdroidkidp.ui.custom.ClipBackgroundConstraintLayout
    android:background="@drawable/parent_safe_browser_item_bg"
    android:paddingTop="4.0dip"
    android:paddingBottom="4.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <com.sand.airdroidkidp.ui.custom.IconItemMorePreference
        android:id="@id/iimpManage"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:icon="@drawable/control_svg"
        app:isShowDivider="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/Parent_Safe_Browser_Manage_Title" />
    <com.sand.airdroidkidp.ui.custom.IconItemMorePreference
        android:id="@id/iimpUrlBlack"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:icon="@drawable/browser_blacklist_svg"
        app:isShowDivider="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iimpManage"
        app:title="@string/Parent_Safe_Browser_Manage_Rule_Black_Title" />
    <com.sand.airdroidkidp.ui.custom.IconItemMorePreference
        android:id="@id/iimpUrlWhite"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        app:icon="@drawable/browser_whitelist_svg"
        app:isShowDivider="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iimpUrlBlack"
        app:title="@string/Parent_Safe_Browser_Manage_Rule_White_Title" />
</com.sand.airdroidkidp.ui.custom.ClipBackgroundConstraintLayout>