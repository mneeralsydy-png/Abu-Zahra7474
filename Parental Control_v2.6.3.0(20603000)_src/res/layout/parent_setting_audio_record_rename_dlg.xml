<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:theme="@style/AppTheme"
    android:orientation="vertical"
    android:background="@drawable/parent_bind_code_dlg_bg"
    android:padding="20.0dip"
    android:layout_width="@dimen/dialog_max_width"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <TextView
        android:textSize="18.0sp"
        android:textStyle="bold"
        android:textColor="@color/black_404040"
        android:gravity="center"
        android:id="@id/tvAudioRenameTitle"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="@string/Parent_Setting_Records_Rename"
        android:layout_marginStart="25.0dip"
        android:layout_marginEnd="25.0dip" />
    <com.sand.airdroidkid.common.ui.base.NewCleanableEditText
        android:id="@id/etAudioRenameEdit"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12.0dip"
        android:layout_below="@id/tvAudioRenameTitle"
        app:textPassword="false" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/grey_a4a8b3"
        android:gravity="center"
        android:id="@id/tvAudioRenameCancel"
        android:background="@drawable/ad_dlg_btn_color_bg"
        android:layout_width="fill_parent"
        android:layout_height="44.0dip"
        android:layout_marginTop="6.0dip"
        android:text="@string/Common_Cancel"
        android:layout_below="@id/tvAudioRenameOK"
        app:fontFamily="@font/font_family_medium" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/white_ffffff"
        android:gravity="center"
        android:id="@id/tvAudioRenameOK"
        android:background="@drawable/kid_blue_button_style"
        android:layout_width="fill_parent"
        android:layout_height="44.0dip"
        android:layout_marginTop="30.0dip"
        android:text="@string/Common_OK2"
        android:layout_below="@id/etAudioRenameEdit"
        app:fontFamily="@font/font_family_semi_bold" />
</RelativeLayout>