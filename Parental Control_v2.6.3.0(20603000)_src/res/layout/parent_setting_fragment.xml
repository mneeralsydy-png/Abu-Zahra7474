<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/white_ffffff"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glScrollViewStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="@dimen/global_start_percent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@id/glScrollViewEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="@dimen/global_end_percent" />
    <View
        android:background="@drawable/parent_profile_item_bg"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="@id/ivProfileBg"
        app:layout_constraintEnd_toEndOf="@id/ivProfileBg"
        app:layout_constraintStart_toStartOf="@id/ivProfileBg"
        app:layout_constraintTop_toTopOf="@id/ivProfileBg" />
    <ImageView
        android:id="@id/ivProfileBg"
        android:background="@drawable/parent_profile_bg"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/pic_aboutme"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        android:contentDescription="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <include
        android:id="@id/profileLayout"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        layout="@layout/parent_profile_item" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@id/glBgBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.3" />
    <androidx.core.widget.NestedScrollView
        android:paddingBottom="16.0dip"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:layout_width="0.0dip"
        android:layout_height="0.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/glScrollViewEnd"
        app:layout_constraintStart_toStartOf="@id/glScrollViewStart"
        app:layout_constraintTop_toBottomOf="@id/profileLayout">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <include
                android:id="@id/profileMineLayout"
                layout="@layout/profile_mine_layout" />
            <include
                android:id="@id/profileHelpLayout"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12.0dip"
                layout="@layout/profile_help_layout" />
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/gray_666b75"
                android:gravity="center"
                android:id="@id/tvLogout"
                android:background="@drawable/parent_profile_background"
                android:padding="12.0dip"
                android:layout_width="fill_parent"
                android:layout_height="54.0dip"
                android:layout_marginTop="12.0dip"
                android:text="@string/Profile_Logout_Title"
                app:fontFamily="@font/font_family_medium" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>