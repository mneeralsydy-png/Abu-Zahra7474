<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@android:color/white"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/parentSearchView"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20.0dip"
        android:layout_marginTop="10.0dip"
        android:layout_marginRight="20.0dip"
        android:layout_marginBottom="10.0dip"
        android:layout_marginHorizontal="20.0dip"
        android:layout_marginVertical="10.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tbSingleSelect"
        layout="@layout/parent_search_bar_layout" />
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@id/llEmpty"
        android:background="@android:color/white"
        android:visibility="visible"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tbSingleSelect">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@id/ivEmptyIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/not_recording" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/black_666B75"
            android:gravity="center_horizontal"
            android:id="@id/tvEmptyTip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30.0dip"
            android:layout_marginTop="24.0dip"
            android:layout_marginRight="30.0dip"
            android:text="@string/Common_no_data"
            android:layout_marginHorizontal="30.0dip" />
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/rvSingleList"
        android:background="@android:color/white"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginTop="16.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/parentSearchView" />
    <com.sand.airdroidkidp.ui.custom.ParentProfileToolbar
        android:id="@id/tbSingleSelect"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:minHeight="?actionBarSize"
        app:isDividerVisible="false"
        app:layout_constraintTop_toTopOf="parent"
        app:rightIcon="@drawable/select_all"
        app:title="@string/Parent_Setting_My_Recordings"
        app:toolbarMode="2" />
</androidx.constraintlayout.widget.ConstraintLayout>