<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    android:background="@drawable/footer_bg"
    android:paddingLeft="20.0dip"
    android:paddingRight="20.0dip"
    android:paddingBottom="30.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:maxWidth="@dimen/tablet_max_width"
    android:paddingHorizontal="20.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:layout_gravity="center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.0dip"
        android:src="@drawable/bottom_sheet_mark"
        android:layout_centerHorizontal="true" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/flAvatar"
        android:padding="4.0dip"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30.0dip"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@id/ivArrow"
            android:layout_width="64.0dip"
            android:layout_height="64.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/account" />
        <ImageView
            android:layout_gravity="bottom|center"
            android:background="@drawable/camera_setting_bg"
            android:padding="6.0dip"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip"
            android:elevation="3.0dip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_camera_svg" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.sand.airdroidkid.common.ui.base.NewCleanableEditText
        android:id="@id/etPhone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24.0dip"
        android:hint="@string/Common_name"
        android:singleLine="true"
        android:layout_below="@id/flAvatar"
        android:fontFamily="@font/font_family_semi_bold" />
    <TextView
        android:textSize="12.0sp"
        android:textColor="@color/red_e13e3e"
        android:id="@id/tvPhoneErrorTitle"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Common_rename_empty"
        android:layout_below="@id/etPhone" />
    <com.sand.airdroidkid.common.ui.base.NewCleanableEditText
        android:id="@id/etNote"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24.0dip"
        android:text=""
        android:hint="@string/Parent_Device_Edit_Enter_Note"
        android:singleLine="true"
        android:layout_below="@id/tvPhoneErrorTitle"
        android:fontFamily="@font/font_family_semi_bold" />
    <TextView
        android:textSize="12.0sp"
        android:textColor="@color/red_e13e3e"
        android:id="@id/tvNoteErrorTitle"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Account_Signup_Emoji_NotAllow"
        android:layout_below="@id/etNote" />
    <View
        android:id="@id/vDivider"
        android:background="@color/border_200"
        android:layout_width="fill_parent"
        android:layout_height="1.0dip"
        android:layout_marginTop="24.0dip"
        android:layout_below="@id/tvNoteErrorTitle" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/liHideDevice"
        android:layout_width="fill_parent"
        android:layout_height="48.0dip"
        android:layout_marginTop="12.0dip"
        android:layout_below="@id/vDivider">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/account_manage_svg" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/text_100"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/parent_edit_deviceinfo_hidedevice_button"
            android:maxLines="2"
            android:fontFamily="@font/font_family_medium"
            android:layout_marginStart="14.0dip" />
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@id/imHideHintIcon"
            android:layout_width="14.0dip"
            android:layout_height="14.0dip"
            android:src="@drawable/ic_help_a4a8b3"
            android:layout_marginStart="5.0dip" />
        <View
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_weight="1.0" />
        <ToggleButton
            android:layout_gravity="center_vertical"
            android:id="@id/tbIsHideDevice"
            android:background="@drawable/toggle_button"
            android:visibility="visible"
            android:layout_width="42.0dip"
            android:layout_height="24.0dip"
            android:checked="false"
            android:textOn=""
            android:textOff="" />
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@id/liUnbindDevice"
        android:layout_width="fill_parent"
        android:layout_height="48.0dip"
        android:layout_below="@id/liHideDevice">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/unbundle" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/text_100"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/unbind_device"
            android:maxLines="2"
            android:fontFamily="@font/font_family_medium"
            android:layout_marginStart="14.0dip" />
        <View
            android:layout_width="0.0dip"
            android:layout_height="0.0dip"
            android:layout_weight="1.0" />
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/more" />
    </LinearLayout>
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/white_ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/tvEnter"
        android:background="@drawable/kid_blue_button_style"
        android:layout_width="fill_parent"
        android:layout_height="44.0dip"
        android:layout_marginTop="16.0dip"
        android:minWidth="74.0dip"
        android:text="@string/Common_OK2"
        android:maxLines="1"
        android:layout_below="@id/liUnbindDevice"
        app:fontFamily="@font/font_family_semi_bold" />
</RelativeLayout>