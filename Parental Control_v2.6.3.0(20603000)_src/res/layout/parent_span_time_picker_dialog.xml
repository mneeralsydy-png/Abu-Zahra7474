<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/location_dialog_bg"
    android:paddingTop="10.0dip"
    android:paddingBottom="30.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:maxWidth="@dimen/tablet_max_width"
    android:paddingStart="20.0dip"
    android:paddingEnd="20.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/ivHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/bottom_sheet_mark"
        android:contentDescription="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/black_282930"
        android:id="@id/tvStartTimeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20.0dip"
        android:text="@string/Parent_UsageLimit_Start"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/to"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivHeader" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/black_282930"
        android:id="@id/tvEndTimeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20.0dip"
        android:text="@string/Parent_UsageLimit_End"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/to"
        app:layout_constraintTop_toBottomOf="@id/ivHeader" />
    <TimePicker
        android:id="@id/tpStartTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:timePickerMode="spinner"
        app:layout_constraintEnd_toStartOf="@id/to"
        app:layout_constraintTop_toBottomOf="@id/tvStartTimeTitle" />
    <TextView
        android:textSize="20.0sp"
        android:textStyle="bold"
        android:textColor="#ff797979"
        android:id="@id/to"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/time_gap"
        app:layout_constraintBottom_toBottomOf="@id/tpStartTime"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tpStartTime" />
    <TimePicker
        android:id="@id/tpEndTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:timePickerMode="spinner"
        app:layout_constraintStart_toEndOf="@id/to"
        app:layout_constraintTop_toBottomOf="@id/tvEndTimeTitle" />
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/white_ffffff"
        android:gravity="center"
        android:id="@id/tvOK"
        android:background="@drawable/kid_blue_button_style"
        android:layout_width="0.0dip"
        android:layout_height="44.0dip"
        android:text="@string/Common_OK2"
        app:fontFamily="@font/font_family_semi_bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tpStartTime" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/gray_a4a8b3"
        android:gravity="center"
        android:id="@id/tvCancel"
        android:background="@drawable/ad_dlg_btn_color_bg"
        android:layout_width="0.0dip"
        android:layout_height="44.0dip"
        android:layout_marginTop="14.0dip"
        android:text="@string/Common_Cancel"
        app:fontFamily="@font/font_family_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOK" />
</androidx.constraintlayout.widget.ConstraintLayout>