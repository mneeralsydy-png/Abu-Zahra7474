<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/bg_150"
    android:paddingTop="10.0dip"
    android:paddingBottom="10.0dip"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:paddingVertical="10.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ProgressBar
        android:id="@id/progress"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <androidx.constraintlayout.widget.Guideline
        android:orientation="horizontal"
        android:id="@id/glViewTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.2" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/clEmpty"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/glViewTop"
        app:layout_constraintWidth_max="@dimen/tablet_max_width">
        <ImageView
            android:id="@id/ivUsageTime"
            android:layout_width="190.0dip"
            android:layout_height="140.0dip"
            android:src="@drawable/pic_limit_deactivate"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:textSize="16.0sp"
            android:textColor="@android:color/white"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@id/tvEmptyAddLimit"
            android:background="@drawable/kid_blue_button_style"
            android:paddingLeft="40.0dip"
            android:paddingRight="40.0dip"
            android:layout_width="wrap_content"
            android:layout_height="44.0dip"
            android:layout_marginLeft="25.0dip"
            android:layout_marginTop="48.0dip"
            android:layout_marginRight="25.0dip"
            android:minWidth="192.0dip"
            android:text="@string/Parent_AppLimits_Add_Limit"
            android:maxLines="1"
            android:layout_marginHorizontal="25.0dip"
            android:paddingHorizontal="40.0dip"
            app:fontFamily="@font/font_family_semi_bold"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_min="36.0dip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUsageTimeHint"
            app:layout_constraintWidth_min="196.0dip" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/black_282930"
            android:gravity="center"
            android:id="@id/tvUsageTimeHint"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="15.0dip"
            android:text="@string/Parent_UsageLimit_App_Empty_Title"
            android:minLines="3"
            android:layout_marginStart="20.0dip"
            android:layout_marginEnd="20.0dip"
            app:fontFamily="@font/font_family_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivUsageTime" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <include
        android:id="@id/layout_enable_limit_view"
        android:visibility="gone"
        layout="@layout/parent_enable_limit_view" />
    <include
        android:id="@id/layout_no_network"
        android:visibility="gone"
        layout="@layout/layout_no_network" />
</androidx.constraintlayout.widget.ConstraintLayout>