<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:orientation="vertical"
    android:background="@color/grey_f4f4f4"
    android:paddingBottom="20.0dip"
    android:scrollbars="vertical"
    android:clipToPadding="false"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:overScrollMode="ifContentScrolls"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.core.widget.NestedScrollView
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glStart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/global_start_percent" />
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@id/glEnd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="@dimen/global_end_percent" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                app:layout_constraintEnd_toEndOf="@id/glEnd"
                app:layout_constraintStart_toStartOf="@id/glStart"
                app:layout_constraintTop_toTopOf="parent">
                <com.sand.airdroidkidp.feature.usagetime.component.UsageLimitNamePreference
                    android:id="@id/tgUsageLimitPreference"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18.0dip"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@id/clAddUrl"
                    android:visibility="gone"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20.0dip"
                    android:layout_marginBottom="20.0dip"
                    app:layout_constraintBottom_toTopOf="@id/tvLimitType"
                    app:layout_constraintTop_toBottomOf="@id/tgUsageLimitPreference">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="13.0sp"
                        android:id="@id/tvUrlLimitTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/Parental_WebLimit_Limit_Url"
                        android:layout_marginStart="16.0dip"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <include
                        android:id="@id/itemAddOptionLayout"
                        android:layout_width="0.0dip"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10.0dip"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvUrlLimitTitle"
                        layout="@layout/add_url_option_layout" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@id/rvDomainList"
                        android:background="@drawable/usage_limit_bg"
                        android:visibility="gone"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10.0dip"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/itemAddOptionLayout" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="13.0sp"
                    android:id="@id/tvLimitType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18.0dip"
                    android:text="@string/Parent_UsageLimit_Type_Title"
                    android:layout_marginStart="16.0dip"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clAddUrl" />
                <RadioGroup
                    android:id="@id/rgLimitType"
                    android:background="@drawable/usage_limit_bg"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.0dip"
                    android:divider="@drawable/radio_group_divider"
                    android:showDividers="middle"
                    android:dividerPadding="16.0dip"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvLimitType">
                    <com.sand.airdroidkidp.ui.custom.SubtitleRadioButton
                        android:id="@id/rbTimeLimit"
                        android:background="@color/ad_transparent"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16.0dip"
                        android:layout_marginTop="16.0dip"
                        android:layout_marginRight="16.0dip"
                        android:layout_marginBottom="16.0dip"
                        android:checked="true"
                        android:button="@null"
                        android:drawablePadding="5.0dip"
                        android:drawableEnd="@drawable/select_app_box_style"
                        android:layout_marginHorizontal="16.0dip"
                        android:layout_marginVertical="16.0dip"
                        app:subtitleText="@string/Parent_UsageLimit_ScreenTime_UsageTime"
                        app:subtitleTextAppearance="@style/ad_textAppearance_radio_subtitle"
                        app:titleText="@string/Parent_UsageLimit_Time_Title"
                        app:titleTextAppearance="@style/ad_textAppearance_radio_title"
                        app:titleTextFont="@font/font_family_medium" />
                    <com.sand.airdroidkidp.ui.custom.SubtitleRadioButton
                        android:id="@id/rbTimeSeparateLimit"
                        android:background="@color/ad_transparent"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16.0dip"
                        android:layout_marginTop="16.0dip"
                        android:layout_marginRight="16.0dip"
                        android:layout_marginBottom="16.0dip"
                        android:checked="true"
                        android:button="@null"
                        android:drawablePadding="5.0dip"
                        android:drawableEnd="@drawable/select_app_box_style"
                        android:layout_marginHorizontal="16.0dip"
                        android:layout_marginVertical="16.0dip"
                        app:subtitleText="@string/Device_UsageLimit_Per_App_Description"
                        app:subtitleTextAppearance="@style/ad_textAppearance_radio_subtitle"
                        app:titleText="@string/Device_UsageLimit_Per_App_Time_Limit"
                        app:titleTextAppearance="@style/ad_textAppearance_radio_title"
                        app:titleTextFont="@font/font_family_medium" />
                    <com.sand.airdroidkidp.ui.custom.SubtitleRadioButton
                        android:id="@id/rbTimeSpanLimit"
                        android:background="@color/ad_transparent"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16.0dip"
                        android:layout_marginTop="12.0dip"
                        android:layout_marginRight="16.0dip"
                        android:layout_marginBottom="12.0dip"
                        android:button="@null"
                        android:drawablePadding="5.0dip"
                        android:drawableEnd="@drawable/select_app_box_style"
                        android:layout_marginHorizontal="16.0dip"
                        android:layout_marginVertical="12.0dip"
                        app:subtitleText="@string/Parent_UsageLimit_ScreenTime_Disable_Period"
                        app:subtitleTextAppearance="@style/ad_textAppearance_radio_subtitle"
                        app:titleText="@string/Kid_Home_Downtime"
                        app:titleTextAppearance="@style/ad_textAppearance_radio_title"
                        app:titleTextFont="@font/font_family_medium" />
                </RadioGroup>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="13.0sp"
                    android:id="@id/tvLimitOption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="21.0dip"
                    android:text="@string/Parent_UsageLimit_Type_Option"
                    android:layout_marginStart="16.0dip"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rgLimitType" />
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@id/clLimits"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvLimitOption">
                    <com.sand.airdroidkidp.feature.usagetime.component.TimeLimitRadioGroupPreference
                        android:id="@id/rgUsageLimit"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10.0dip"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@id/rvCustomizeTime"
                        android:background="@drawable/usage_limit_bg"
                        android:visibility="gone"
                        android:layout_width="0.0dip"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dip"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/rgUsageLimit" />
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@id/clAvailableTime"
                        android:background="@drawable/usage_limit_bg"
                        android:paddingTop="16.0dip"
                        android:paddingBottom="16.0dip"
                        android:visibility="visible"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dip"
                        android:minHeight="44.0dip"
                        android:paddingVertical="16.0dip"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/rgUsageLimit">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="15.0sp"
                            android:textColor="@color/black_282930"
                            android:ellipsize="end"
                            android:gravity="start|center"
                            android:id="@id/tvAvailableTimeTitle"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:text="@string/downtime_time"
                            android:maxLines="3"
                            android:layout_marginStart="16.0dip"
                            app:fontFamily="@font/font_family_medium"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/tvAvailableTime"
                            app:layout_constraintHorizontal_chainStyle="spread_inside"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="13.0sp"
                            android:textColor="@color/gray_ff878d9a"
                            android:ellipsize="end"
                            android:gravity="end|center"
                            android:id="@id/tvAvailableTime"
                            android:layout_width="0.0dip"
                            android:layout_height="wrap_content"
                            android:minWidth="80.0dip"
                            android:text="@string/Parent_UsageLimit_EveryDay_Custom_Period"
                            android:maxLines="3"
                            android:layout_marginStart="10.0dip"
                            android:layout_marginEnd="4.0dip"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivLimitEndArrow"
                            app:layout_constraintHorizontal_chainStyle="spread_inside"
                            app:layout_constraintStart_toEndOf="@id/tvAvailableTimeTitle"
                            app:layout_constraintTop_toTopOf="parent" />
                        <ImageView
                            android:id="@id/ivLimitEndArrow"
                            android:background="@drawable/more"
                            android:layout_width="14.0dip"
                            android:layout_height="14.0dip"
                            android:layout_marginEnd="16.0dip"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="13.0sp"
                    android:textColor="@color/gray_878d9a"
                    android:id="@id/tvGeofenceLimitTitle"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20.0dip"
                    android:text="@string/Parent_Geofence"
                    android:layout_marginStart="16.0dip"
                    android:layout_marginEnd="16.0dip"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clLimits" />
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@id/clGeofenceLimit"
                    android:background="@drawable/usage_limit_bg"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.0dip"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGeofenceLimitTitle">
                    <TextView
                        android:textSize="15.0sp"
                        android:textColor="@color/black_282930"
                        android:id="@id/tvOpenUsageGeofenceLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16.0dip"
                        android:layout_marginBottom="16.0dip"
                        android:text="@string/Parent_UsageLimit_Location_Range_Enable"
                        android:layout_marginStart="16.0dip"
                        app:fontFamily="@font/font_family_medium"
                        app:layout_constraintBottom_toTopOf="@id/vDividerOpenUsageGeofenceLimit"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <ToggleButton
                        android:id="@id/tgOpenUsageGeofenceLimit"
                        android:background="@drawable/toggle_button"
                        android:saveEnabled="false"
                        android:layout_width="42.0dip"
                        android:layout_height="24.0dip"
                        android:checked="false"
                        android:textOn=""
                        android:textOff=""
                        android:layout_marginEnd="16.0dip"
                        app:layout_constraintBottom_toBottomOf="@id/tvOpenUsageGeofenceLimit"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvOpenUsageGeofenceLimit" />
                    <View
                        android:id="@id/vDividerOpenUsageGeofenceLimit"
                        android:background="@color/parent_divider_bg"
                        android:visibility="gone"
                        android:layout_width="0.0dip"
                        android:layout_height="1.0dip"
                        android:layout_marginStart="16.0dip"
                        android:layout_marginEnd="16.0dip"
                        app:layout_constraintBottom_toTopOf="@id/tvGeofenceAddressTitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvOpenUsageGeofenceLimit" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="15.0sp"
                        android:textColor="@color/black_282930"
                        android:ellipsize="end"
                        android:gravity="start|center"
                        android:id="@id/tvGeofenceAddressTitle"
                        android:visibility="gone"
                        android:layout_width="0.0dip"
                        android:layout_height="22.0dip"
                        android:layout_marginTop="12.0dip"
                        android:layout_marginBottom="12.0dip"
                        android:text="@string/Parent_UsageLimit_Select_Position"
                        android:maxLines="3"
                        android:layout_marginStart="16.0dip"
                        app:fontFamily="@font/font_family_medium"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/vDividerOpenUsageGeofenceLimit" />
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="13.0sp"
                        android:textColor="@color/gray_ff878d9a"
                        android:ellipsize="end"
                        android:gravity="end|center"
                        android:id="@id/tvSelectGeofenceAddress"
                        android:visibility="gone"
                        android:layout_width="0.0dip"
                        android:layout_height="wrap_content"
                        android:minWidth="80.0dip"
                        android:text="@string/Parent_UsageLimit_Select_Position_Placeholder"
                        android:maxLines="1"
                        android:layout_marginStart="10.0dip"
                        android:layout_marginEnd="4.0dip"
                        app:layout_constraintBottom_toBottomOf="@id/tvGeofenceAddressTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivUsageGeofenceLimitArrow"
                        app:layout_constraintStart_toEndOf="@id/tvGeofenceAddressTitle"
                        app:layout_constraintTop_toTopOf="@id/tvGeofenceAddressTitle" />
                    <ImageView
                        android:id="@id/ivUsageGeofenceLimitArrow"
                        android:background="@drawable/more"
                        android:visibility="gone"
                        android:layout_width="14.0dip"
                        android:layout_height="14.0dip"
                        android:layout_marginEnd="16.0dip"
                        app:layout_constraintBottom_toBottomOf="@id/tvGeofenceAddressTitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvGeofenceAddressTitle" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="12.0sp"
                    android:textColor="@color/gray_878d9a"
                    android:id="@id/tvGeofenceLimitHint"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8.0dip"
                    android:text="@string/Parent_UsageLimit_Location_Range_Title"
                    android:layout_marginStart="16.0dip"
                    android:layout_marginEnd="16.0dip"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clGeofenceLimit" />
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@id/clCategoryApps"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGeofenceLimitHint">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="13.0sp"
                        android:textColor="@color/gray_878d9a"
                        android:id="@id/tvCategoryAppsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20.0dip"
                        android:text="@string/Parent_UsageLimit_Category_And_App"
                        android:layout_marginStart="16.0dip"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@id/rvAppLimits"
                        android:background="@drawable/usage_limit_bg"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8.0dip"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvCategoryAppsTitle" />
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="15.0sp"
                    android:textColor="@color/red_e13e3e"
                    android:gravity="center"
                    android:id="@id/tvDeleteLimits"
                    android:background="@drawable/usage_limit_bg"
                    android:layout_width="fill_parent"
                    android:layout_height="44.0dip"
                    android:layout_marginTop="20.0dip"
                    android:layout_marginBottom="20.0dip"
                    android:text="@string/Parent_UsageLimit_Delete_Title"
                    android:layout_marginVertical="20.0dip"
                    app:fontFamily="@font/font_family_medium"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/clCategoryApps" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <ProgressBar
        android:id="@id/pbRefresh"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/colorPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>