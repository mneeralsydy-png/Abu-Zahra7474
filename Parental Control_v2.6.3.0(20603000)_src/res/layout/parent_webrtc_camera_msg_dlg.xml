<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="@drawable/parent_bind_code_dlg_bg"
    android:paddingLeft="20.0dip"
    android:paddingTop="20.0dip"
    android:paddingRight="20.0dip"
    android:paddingBottom="12.0dip"
    android:layout_width="@dimen/dialog_max_width"
    android:layout_height="wrap_content"
    android:paddingHorizontal="20.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <TextView
        android:textSize="30.0sp"
        android:layout_gravity="center"
        android:background="@drawable/pic_camera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <TextView
        android:textSize="18.0sp"
        android:textColor="@color/black_282930"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14.0dip"
        android:text="@string/Parent_Device_Remote_Camera_Title"
        app:fontFamily="@font/font_family_semi_bold" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/black_ff464f60"
        android:gravity="start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14.0dip"
        android:text="@string/Parent_Device_Remote_Camera_Subtitle"
        android:lineSpacingMultiplier="1.2"
        android:breakStrategy="simple" />
    <RelativeLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14.0dip">
        <ToggleButton
            android:id="@id/tbNoShowWebRtcMsg"
            android:visibility="visible"
            android:layout_width="14.0dip"
            android:layout_height="18.0dip"
            android:checked="false"
            android:button="@drawable/radio_button_selector"
            android:layout_centerVertical="true"
            android:backgroundTint="@color/color_white" />
        <TextView
            android:textSize="13.0sp"
            android:textColor="@color/gray_878d9a"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Parent_No_prompt"
            android:layout_centerVertical="true"
            android:layout_marginStart="11.0dip"
            android:layout_toEndOf="@id/tbNoShowWebRtcMsg" />
    </RelativeLayout>
    <TextView
        android:textSize="16.0sp"
        android:textColor="@color/white_ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/tvOK"
        android:background="@drawable/kid_blue_button_style"
        android:layout_width="fill_parent"
        android:layout_height="44.0dip"
        android:layout_marginTop="30.0dip"
        android:minWidth="75.0dip"
        android:text="@string/Common_continue_button"
        android:maxLines="1"
        app:fontFamily="@font/font_family_semi_bold" />
    <TextView
        android:textSize="14.0sp"
        android:textColor="@color/gray_a4a8b3"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@id/tvCancel"
        android:background="@drawable/ad_dlg_btn_color_bg"
        android:layout_width="fill_parent"
        android:layout_height="44.0dip"
        android:layout_marginTop="6.0dip"
        android:minWidth="75.0dip"
        android:text="@string/Common_Cancel"
        android:maxLines="1"
        app:fontFamily="@font/font_family_medium" />
</LinearLayout>