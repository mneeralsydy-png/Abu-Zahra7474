<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/white_ffffff"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.core.widget.NestedScrollView
        android:id="@id/permissionFailedScrollView"
        android:paddingBottom="20.0dip"
        android:clipToPadding="false"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:fillViewport="true">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@id/clError"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@id/ivLogo"
                    android:layout_width="0.0dip"
                    android:layout_height="0.0dip"
                    android:src="@drawable/pic_permiss_error"
                    app:layout_constrainedHeight="true"
                    app:layout_constraintDimensionRatio="h,45:27"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:textSize="18.0sp"
                    android:textColor="@color/black_282930"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@id/tvDeviceName"
                    android:layout_width="0.0dip"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20.0dip"
                    android:layout_marginTop="14.0dip"
                    android:layout_marginRight="20.0dip"
                    android:maxLines="1"
                    android:layout_marginHorizontal="20.0dip"
                    app:fontFamily="@font/font_family_semi_bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ivLogo"
                    app:layout_constraintWidth_max="@dimen/tablet_max_width" />
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="@color/white_ffffff"
                    android:gravity="center"
                    android:id="@id/tvHintMessage"
                    android:background="@drawable/permission_check_failed_text_bg"
                    android:paddingLeft="5.0dip"
                    android:paddingTop="1.0dip"
                    android:paddingRight="5.0dip"
                    android:paddingBottom="1.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20.0dip"
                    android:layout_marginTop="10.0dip"
                    android:layout_marginRight="20.0dip"
                    android:text="@string/Parent_Permission_Abnormal_Text"
                    android:layout_marginHorizontal="20.0dip"
                    android:paddingHorizontal="5.0dip"
                    android:paddingVertical="1.0dip"
                    app:layout_constrainedHeight="true"
                    app:layout_constrainedWidth="true"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDeviceName" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <View
                android:id="@id/vPermissionFailedTitleMark"
                android:background="@drawable/bg_blue_radius_2"
                android:layout_width="4.0dip"
                android:layout_height="14.0dip"
                app:layout_constraintBottom_toBottomOf="@id/tvPermissionFailedTitle"
                app:layout_constraintStart_toStartOf="@id/permissionFailedList"
                app:layout_constraintTop_toTopOf="@id/tvPermissionFailedTitle" />
            <TextView
                android:textSize="14.0sp"
                android:textColor="@color/black_282930"
                android:id="@id/tvPermissionFailedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40.0dip"
                android:text="@string/Parental_Permission_No_Open"
                android:layout_marginStart="10.0dip"
                app:fontFamily="@font/font_family_semi_bold"
                app:layout_constraintStart_toStartOf="@id/vPermissionFailedTitleMark"
                app:layout_constraintTop_toBottomOf="@id/clError" />
            <include
                android:id="@id/permissionFailedList"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20.0dip"
                android:layout_marginTop="10.0dip"
                android:layout_marginRight="20.0dip"
                android:layout_marginHorizontal="20.0dip"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPermissionFailedTitle"
                app:layout_constraintWidth_max="@dimen/tablet_max_width"
                layout="@layout/permission_failed_list" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>