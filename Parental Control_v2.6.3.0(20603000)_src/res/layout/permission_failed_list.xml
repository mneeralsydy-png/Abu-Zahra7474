        app:title="@string/Parent_Device_Screenshot_Title" />
    <com.sand.airdroidkidp.ui.custom.PermissionFailedItemPreference
        android:id="@id/itemAudio"
        android:visibility="gone"
        android:layout_width="fill_parent"
