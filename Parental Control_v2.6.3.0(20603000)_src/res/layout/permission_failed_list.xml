        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/itemHistoryLocation"
        app:title="@string/pc_biz_intro_feature4_title" />
    <com.sand.airdroidkidp.ui.custom.PermissionMultiFailedItemPreference
        android:id="@id/itemAppList"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
