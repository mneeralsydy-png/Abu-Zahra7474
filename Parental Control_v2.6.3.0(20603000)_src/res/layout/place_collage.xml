<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:paddingBottom="?placesSpacingLarge"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:id="@id/place_collage"
        android:layout_width="fill_parent"
        android:layout_height="0.0dip"
        android:layout_marginBottom="?placesSpacingExtraLarge"
        android:layout_marginStart="?placesSpacingExtraLarge"
        android:layout_marginEnd="?placesSpacingExtraLarge"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="?placesCornerRadiusCollageOuter"
        app:cardElevation="0.0dip"
        app:layout_constraintDimensionRatio="H,4:3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent">
            <androidx.cardview.widget.CardView
                android:id="@id/place_image_card"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:cardCornerRadius="@dimen/gmp_sys_shape_corner_extra_small_corner_size"
                app:cardElevation="0.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/place_image_card2"
                app:layout_constraintHorizontal_weight="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@id/place_image"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/place_details_image_content_description" />
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@id/place_image_card2"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                android:layout_marginStart="?placesSpacingExtraSmall"
                app:cardCornerRadius="@dimen/gmp_sys_shape_corner_extra_small_corner_size"
                app:cardElevation="0.0dip"
                app:layout_constraintBottom_toTopOf="@id/place_image_card3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1.0"
                app:layout_constraintStart_toEndOf="@id/place_image_card"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_weight="1.0">
                <ImageView
                    android:id="@id/place_image2"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/place_details_image_content_description" />
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@id/place_image_card3"
                android:visibility="gone"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                android:layout_marginTop="?placesSpacingExtraSmall"
                app:cardCornerRadius="@dimen/gmp_sys_shape_corner_extra_small_corner_size"
                app:cardElevation="0.0dip"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/place_image_card2"
                app:layout_constraintStart_toStartOf="@id/place_image_card2"
                app:layout_constraintTop_toBottomOf="@id/place_image_card2"
                app:layout_constraintVertical_weight="1.0">
                <ImageView
                    android:id="@id/place_image3"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/place_details_image_content_description" />
            </androidx.cardview.widget.CardView>
            <include
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="?placesSpacingMedium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                layout="@layout/place_details_lightbox_hint_badge" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <FrameLayout
            android:id="@id/place_collage_error"
            android:background="?placesColorNeutralContainer"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_weight="1.0">
            <TextView
                android:textAppearance="?placesTextAppearanceBodySmall"
                android:textColor="?placesColorOnNeutralContainer"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/place_photo_viewer_image_load_failed_message" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>