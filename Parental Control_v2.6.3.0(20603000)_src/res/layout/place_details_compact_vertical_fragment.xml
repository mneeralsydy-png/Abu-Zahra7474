<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:id="@id/place_details_compact_vertical_card"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:importantForAccessibility="no"
    app:cardCornerRadius="?placesCornerRadius"
    app:cardElevation="0.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@id/place_details_compact_layout"
        android:background="?placesColorSurface"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:foreground="@drawable/place_widgets_foreground">
        <FrameLayout
            android:id="@id/place_image_container"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            app:layout_constraintDimensionRatio="H,3:2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@id/place_image"
                android:background="?placesColorNeutralContainer"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:contentDescription="@string/place_details_image_content_description"
                android:elevation="0.0dip"
                app:shapeAppearanceOverlay="@style/PlaceImageCornerShape"
                app:strokeColor="?placesColorOutlineDecorative"
                app:strokeWidth="?placesBorderWidth" />
            <TextView
                android:textAppearance="?placesTextAppearanceBodySmall"
                android:textColor="?placesColorOnSurfaceVariant"
                android:gravity="center"
                android:id="@id/image_loading_failure"
                android:background="@android:color/transparent"
                android:padding="?placesSpacingMedium"
                android:visibility="gone"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:text="@string/place_photo_viewer_image_load_failed_message"
                android:textDirection="locale"
                android:layoutDirection="locale"
                android:elevation="1.0dip" />
        </FrameLayout>
        <include
            android:id="@id/place_content"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/place_image_container"
            layout="@layout/place_details_compact_content" />
        <Button
            android:textAppearance="?placesTextAppearanceLabelLarge"
            android:textColor="?placesColorOnSecondaryContainer"
            android:id="@id/open_in_maps"
            android:background="@drawable/places_widgets_button_background"
            android:paddingTop="@dimen/place_details_widget_full_button_vertical_padding"
            android:paddingBottom="@dimen/place_details_widget_full_button_vertical_padding"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="?placesSpacingExtraSmall"
            android:layout_marginBottom="?placesSpacingMedium"
            android:minWidth="0.0dip"
            android:minHeight="0.0dip"
            android:text="@string/place_details_maps_button_label"
            android:drawablePadding="?placesSpacingExtraSmall"
            android:contentDescription="@string/place_details_maps_button_a11y_label"
            android:paddingStart="@dimen/place_details_widget_full_button_horizontal_padding"
            android:paddingEnd="@dimen/place_details_widget_full_button_horizontal_padding"
            android:layout_marginStart="?placesSpacingLarge"
            android:layout_marginEnd="?placesSpacingLarge"
            android:stateListAnimator="@null"
            android:drawableTint="?placesColorOnSecondaryContainer"
            app:layout_constraintStart_toStartOf="@id/place_content"
            app:layout_constraintTop_toBottomOf="@id/place_content" />
        <TextView
            android:textAppearance="@style/GoogleMapsTextAttribution"
            android:id="@id/place_details_attribution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/google_maps_text_attribution" />
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@id/legal_disclosures_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/gs_info_vd_24"
            android:scaleType="centerInside"
            android:contentDescription="@string/place_widgets_legal_disclosures_icon_a11y_label" />
        <androidx.constraintlayout.helper.widget.Flow
            android:orientation="horizontal"
            android:paddingTop="?placesSpacingMedium"
            android:paddingBottom="?placesSpacingMedium"
            android:layout_width="0.0dip"
            android:layout_height="fill_parent"
            android:layout_marginStart="?placesSpacingLarge"
            android:layout_marginEnd="?placesSpacingLarge"
            app:constraint_referenced_ids="place_details_attribution,legal_disclosures_icon"
            app:flow_horizontalBias="0.0"
            app:flow_horizontalGap="?placesSpacingSmall"
            app:flow_horizontalStyle="packed"
            app:flow_wrapMode="chain"
            app:layout_constraintEnd_toEndOf="@id/place_content"
            app:layout_constraintStart_toStartOf="@id/place_content"
            app:layout_constraintTop_toBottomOf="@id/open_in_maps" />
        <View
            android:id="@id/place_highlight_scrim"
            android:background="?placesColorOnSurface"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="0.0dip"
            android:alpha="@dimen/place_search_highlight_color_opacity"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>