<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@id/reviews_tab"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <include
        android:id="@id/consumer_alert"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        layout="@layout/consumer_alert" />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@id/reviews_list"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingStart="?placesSpacingExtraLarge"
        android:nestedScrollingEnabled="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/consumer_alert" />
    <TextView
        android:textAppearance="?placesTextAppearanceBodyMedium"
        android:textColor="?placesColorOnSurface"
        android:id="@id/about_reviews"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reviews_disclosure_title"
        android:paddingStart="?placesSpacingExtraLarge"
        android:paddingEnd="?placesSpacingExtraSmall"
        app:layout_constraintBottom_toBottomOf="@id/about_reviews_icon"
        app:layout_constraintEnd_toStartOf="@id/about_reviews_icon"
        app:layout_constraintTop_toTopOf="@id/about_reviews_icon" />
    <ImageView
        android:id="@id/about_reviews_icon"
        android:padding="@dimen/icon_padding_for_min_touch_target_18dp_icon"
        android:layout_width="@dimen/gmp_sys_measurement_tap_target"
        android:layout_height="@dimen/gmp_sys_measurement_tap_target"
        android:src="@drawable/gs_info_vd_24"
        android:tint="?placesColorOnSurfaceVariant"
        android:contentDescription="@string/about_reviews_icon_content_description"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reviews_list" />
</androidx.constraintlayout.widget.ConstraintLayout>