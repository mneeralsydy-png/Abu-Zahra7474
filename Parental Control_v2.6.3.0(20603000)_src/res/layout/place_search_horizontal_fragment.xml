<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:id="@id/place_search_horizontal_card_view"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="?placesCornerRadius"
    app:cardElevation="0.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:background="?placesColorSurface"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:foreground="@drawable/place_widgets_foreground">
        <include
            android:id="@id/place_search_attribution_container_top"
            layout="@layout/place_search_google_maps_attribution" />
        <View
            android:id="@id/place_search_horizontal_top_gap"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="?placesSpacingLarge" />
        <TextView
            android:id="@id/place_search_text_top"
            android:paddingBottom="?placesSpacingLarge"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="?placesSpacingLarge"
            android:paddingEnd="?placesSpacingLarge" />
        <ProgressBar
            android:layout_gravity="center_horizontal"
            android:id="@id/loading_indicator"
            android:visibility="gone"
            android:layout_width="@dimen/gmp_sys_measurement_icon_size_small"
            android:layout_height="@dimen/gmp_sys_measurement_icon_size_small"
            android:layout_marginTop="?placesSpacingLarge"
            android:layout_marginBottom="?placesSpacingLarge"
            android:indeterminate="true"
            android:layout_marginStart="?placesSpacingLarge"
            android:layout_marginEnd="?placesSpacingLarge"
            android:indeterminateTint="?placesColorPrimary" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/place_search_list_recycler_view_container"
            android:clipChildren="false"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <androidx.recyclerview.widget.RecyclerView
                android:orientation="horizontal"
                android:id="@id/place_search_list_recycler_view"
                android:clipToPadding="false"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:paddingStart="?placesSpacingLarge"
                android:paddingEnd="?placesSpacingLarge"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@id/scroller_button"
                android:background="@drawable/place_search_button_background"
                android:visibility="gone"
                android:layout_width="@dimen/gmp_sys_measurement_tap_target"
                android:layout_height="@dimen/gmp_sys_measurement_tap_target"
                android:layout_marginEnd="?placesSpacingMedium"
                android:elevation="@dimen/place_search_widget_button_elevation"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:layout_width="@dimen/gmp_sys_measurement_icon_size_small"
                    android:layout_height="@dimen/gmp_sys_measurement_icon_size_small"
                    android:src="@drawable/gs_arrow_forward_ios_vd_20"
                    android:scaleType="fitCenter"
                    android:tint="?placesColorOnSurface"
                    android:contentDescription="@string/place_search_scroller_button_a11y_label" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:id="@id/place_search_text_bottom"
            android:paddingTop="?placesSpacingLarge"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:paddingStart="?placesSpacingLarge"
            android:paddingEnd="?placesSpacingLarge" />
        <View
            android:id="@id/place_search_horizontal_bottom_gap"
            android:visibility="gone"
            android:layout_width="fill_parent"
            android:layout_height="?placesSpacingLarge" />
        <include
            android:id="@id/place_search_attribution_container_bottom"
            android:visibility="gone"
            layout="@layout/place_search_google_maps_attribution" />
    </LinearLayout>
</androidx.cardview.widget.CardView>