        android:paddingLeft="14.0dip"
        android:paddingRight="14.0dip"
        android:layout_width="wrap_content"
        android:layout_height="48.0dip"
        android:maxWidth="240.0dip"
        android:text="@string/Parental_Request_Join_Always"
        android:lines="1"
        android:paddingHorizontal="14.0dip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDisableThisApp"
        app:layout_constraintWidth_min="140.0dip" />
</androidx.constraintlayout.widget.ConstraintLayout>