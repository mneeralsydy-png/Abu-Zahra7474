<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@drawable/subscribe_banner_radius_box"
    android:paddingTop="8.0dip"
    android:paddingBottom="8.0dip"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@id/start_drawable"
        android:layout_width="16.0dip"
        android:layout_height="16.0dip"
        android:src="@drawable/subscribe_start_drawable"
        android:contentDescription="@string/Free_Feature_Paused_Tip"
        android:layout_marginStart="16.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:textSize="13.0sp"
        android:textColor="@color/color_error_25"
        android:id="@id/text_message"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        android:text="@string/Free_Feature_Paused_Tip"
        android:layout_marginStart="8.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image_more"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toEndOf="@id/start_drawable"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:layout_constraintWidth_max="wrap" />
    <ImageView
        android:id="@id/image_more"
        android:layout_width="9.0dip"
        android:layout_height="9.0dip"
        android:src="@drawable/more"
        android:layout_marginStart="4.0dip"
        android:layout_marginEnd="8.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/close"
        app:layout_constraintStart_toEndOf="@id/text_message"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/color_error_25" />
    <ImageView
        android:id="@id/close"
        android:padding="12.0dip"
        android:layout_width="36.0dip"
        android:layout_height="36.0dip"
        android:src="@drawable/subscribe_banner_close"
        android:layout_marginEnd="4.0dip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>