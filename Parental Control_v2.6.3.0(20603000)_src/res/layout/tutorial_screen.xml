<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:background="@color/black_80282930"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:translationZ="11.0dip"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/dialog"
        android:background="@drawable/bg_radius_16"
        android:layout_width="320.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@id/guide_image"
            android:layout_width="200.0dip"
            android:layout_height="112.0dip"
            android:layout_marginTop="20.0dip"
            android:src="@drawable/pic_guide_pop"
            android:contentDescription="@string/tutorial_dialog_message1" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/text_200"
            android:id="@id/guide_message1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="14.0dip"
            android:layout_marginRight="20.0dip"
            android:text="@string/tutorial_dialog_message1"
            android:layout_marginHorizontal="20.0dip" />
        <TextView
            android:textSize="14.0sp"
            android:textColor="@color/text_200"
            android:id="@id/guide_message2"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="10.0dip"
            android:layout_marginRight="20.0dip"
            android:text="@string/tutorial_dialog_message2"
            android:layout_marginHorizontal="20.0dip" />
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="16.0sp"
            android:textColor="@color/text_600"
            android:id="@id/guide_button"
            android:background="@drawable/kid_blue_button_style"
            android:layout_width="fill_parent"
            android:layout_height="40.0dip"
            android:layout_marginLeft="20.0dip"
            android:layout_marginTop="30.0dip"
            android:layout_marginRight="20.0dip"
            android:text="@string/ad_base_i_know"
            android:fontFamily="@font/font_medium"
            android:stateListAnimator="@null"
            android:layout_marginHorizontal="20.0dip" />
        <FrameLayout
            android:id="@id/padding_bottom"
            android:layout_width="0.0dip"
            android:layout_height="20.0dip" />
    </LinearLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/tutorial_block"
        android:visibility="gone"
        android:layout_width="0.0dip"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_start_percent" />
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@id/glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="@dimen/global_end_percent" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@id/tutorial_bubble"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="@id/glEnd"
            app:layout_constraintHorizontal_bias="@dimen/tutorial_bias"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="420.0dip">
            <ImageView
                android:id="@id/bubble_top"
                android:layout_width="200.0dip"
                android:layout_height="16.0dip"
                android:layout_marginTop="36.0dip"
                android:src="@drawable/pic_guide_top"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <FrameLayout
                android:id="@id/tutorial_rectangle"
                android:background="@drawable/tutorial_purple_bubble"
                android:layout_width="0.0dip"
                android:layout_height="0.0dip"
                app:layout_constraintBottom_toBottomOf="@id/bubble_bottom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bubble_top" />
            <ImageButton
                android:id="@id/tutorial_close"
                android:background="@android:color/transparent"
                android:layout_width="32.0dip"
                android:layout_height="32.0dip"
                android:src="@drawable/tutorial_close"
                android:contentDescription="@string/Common_close"
                app:layout_constraintEnd_toEndOf="@id/tutorial_rectangle"
                app:layout_constraintTop_toTopOf="@id/tutorial_rectangle" />
            <ImageView
                android:id="@id/bubble_book"
                android:layout_width="120.0dip"
                android:layout_height="72.0dip"
                android:layout_marginBottom="10.0dip"
                android:src="@drawable/pic_guide_book"
                android:contentDescription="@null"
                android:layout_marginEnd="32.0dip"
                app:layout_constraintBottom_toTopOf="@id/tutorial_message"
                app:layout_constraintEnd_toEndOf="parent" />
            <TextView
                android:textSize="16.0sp"
                android:textStyle="bold"
                android:textColor="@color/text_600"
                android:id="@id/tutorial_order"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14.0dip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/bubble_top" />
            <TextView
                android:textSize="14.0sp"
                android:textColor="@color/text_600"
                android:id="@id/tutorial_message"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16.0dip"
                android:layout_marginTop="10.0dip"
                android:layout_marginRight="16.0dip"
                android:layout_marginHorizontal="16.0dip"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tutorial_order" />
            <FrameLayout
                android:id="@id/bubble_bottom"
                android:layout_width="0.0dip"
                android:layout_height="50.0dip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tutorial_message" />
            <androidx.appcompat.widget.AppCompatButton
                android:textSize="12.0sp"
                android:textColor="@color/text_600"
                android:id="@id/tutorial_next_button"
                android:background="@drawable/kid_blue_button_style"
                android:paddingLeft="14.0dip"
                android:paddingRight="14.0dip"
                android:layout_width="wrap_content"
                android:layout_height="24.0dip"
                android:layout_marginTop="10.0dip"
                android:minWidth="0.0dip"
                android:text="@string/ad_base_i_know"
                android:stateListAnimator="@null"
                android:paddingHorizontal="14.0dip"
                app:layout_constraintEnd_toEndOf="@id/tutorial_message"
                app:layout_constraintTop_toBottomOf="@id/tutorial_message" />
            <ImageView
                android:id="@id/bubble_arrow"
                android:layout_width="20.0dip"
                android:layout_height="61.0dip"
                android:layout_marginTop="15.0dip"
                android:src="@drawable/pic_guide_arrow"
                android:contentDescription="@null"
                android:layout_marginStart="38.0dip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tutorial_message" />
        </androidx.constraintlayout.widget.ConstraintLayout>
        <FrameLayout
            android:id="@id/highlight_box"
            android:background="@drawable/bg_white_radius_10"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.0dip"
            app:layout_constraintEnd_toEndOf="@id/glEnd"
            app:layout_constraintStart_toStartOf="@id/glStart"
            app:layout_constraintTop_toBottomOf="@id/tutorial_bubble">
            <com.sand.airdroidkidp.ui.custom.FeatureItemPreference
                android:id="@id/highlight_item"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                app:backgroundRes="@drawable/bg_white_radius_10"
                app:icon="@drawable/app_limited"
                app:title="@string/Parent_UsageLimit_AppTime_Title" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>