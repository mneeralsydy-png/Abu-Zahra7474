08R\u001d\u0010k\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008k\u0010\u0006\u001a\u0004\u0008l\u0010\u0008R\u001d\u0010m\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008m\u0010\u0006\u001a\u0004\u0008n\u0010\u0008R\u001d\u0010o\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008o\u0010\u0006\u001a\u0004\u0008p\u0010\u0008R\u001d\u0010q\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008q\u0010\u0006\u001a\u0004\u0008r\u0010\u0008R\u001d\u0010\u0006\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008\u0006\u0010\u0006\u001a\u0004\u0008s\u0010\u0008R\u001d\u0010t\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008t\u0010\u0006\u001a\u0004\u0008u\u0010\u0008R\u001d\u0010v\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008v\u0010\u0006\u001a\u0004\u0008w\u0010\u0008R\u001d\u0010x\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008x\u0010\u0006\u001a\u0004\u0008y\u0010\u0008R\u001d\u0010z\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008z\u0010\u0006\u001a\u0004\u0008{\u0010\u0008R\u001d\u0010|\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008|\u0010\u0006\u001a\u0004\u0008}\u0010\u0008R\u001d\u0010~\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000c\n\u0004\u0008~\u0010\u0006\u001a\u0004\u0008\u007f\u0010\u0008R \u0010\u0080\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0080\u0001\u0010\u0006\u001a\u0005\u0008\u0081\u0001\u0010\u0008R \u0010\u0082\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0082\u0001\u0010\u0006\u001a\u0005\u0008\u0083\u0001\u0010\u0008R \u0010\u0084\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0084\u0001\u0010\u0006\u001a\u0005\u0008\u0085\u0001\u0010\u0008R \u0010\u0086\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0086\u0001\u0010\u0006\u001a\u0005\u0008\u0087\u0001\u0010\u0008R \u0010\u0088\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0088\u0001\u0010\u0006\u001a\u0005\u0008\u0089\u0001\u0010\u0008R \u0010\u008a\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u008a\u0001\u0010\u0006\u001a\u0005\u0008\u008b\u0001\u0010\u0008R \u0010\u008c\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u008c\u0001\u0010\u0006\u001a\u0005\u0008\u008d\u0001\u0010\u0008R \u0010\u008e\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u008e\u0001\u0010\u0006\u001a\u0005\u0008\u008f\u0001\u0010\u0008R\u001e\u0010f\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\r\n\u0004\u0008f\u0010\u0006\u001a\u0005\u0008\u0090\u0001\u0010\u0008R \u0010\u0091\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0091\u0001\u0010\u0006\u001a\u0005\u0008\u0092\u0001\u0010\u0008R \u0010\u0093\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0093\u0001\u0010\u0006\u001a\u0005\u0008\u0094\u0001\u0010\u0008R \u0010\u0095\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0095\u0001\u0010\u0006\u001a\u0005\u0008\u0096\u0001\u0010\u0008R \u0010\u0097\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0097\u0001\u0010\u0006\u001a\u0005\u0008\u0098\u0001\u0010\u0008R \u0010\u0099\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u0099\u0001\u0010\u0006\u001a\u0005\u0008\u009a\u0001\u0010\u0008R \u0010\u009b\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u009b\u0001\u0010\u0006\u001a\u0005\u0008\u009c\u0001\u0010\u0008R \u0010\u009d\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u009d\u0001\u0010\u0006\u001a\u0005\u0008\u009e\u0001\u0010\u0008R \u0010\u009f\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u009f\u0001\u0010\u0006\u001a\u0005\u0008\u00a0\u0001\u0010\u0008R \u0010\u00a1\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00a1\u0001\u0010\u0006\u001a\u0005\u0008\u00a2\u0001\u0010\u0008R \u0010\u00a3\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00a3\u0001\u0010\u0006\u001a\u0005\u0008\u00a4\u0001\u0010\u0008R \u0010\u00a5\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00a5\u0001\u0010\u0006\u001a\u0005\u0008\u00a6\u0001\u0010\u0008R \u0010\u00a7\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00a7\u0001\u0010\u0006\u001a\u0005\u0008\u00a8\u0001\u0010\u0008R \u0010\u00a9\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00a9\u0001\u0010\u0006\u001a\u0005\u0008\u00aa\u0001\u0010\u0008R \u0010\u00ab\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00ab\u0001\u0010\u0006\u001a\u0005\u0008\u00ac\u0001\u0010\u0008R \u0010\u00ad\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00ad\u0001\u0010\u0006\u001a\u0005\u0008\u00ae\u0001\u0010\u0008R \u0010\u00af\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00af\u0001\u0010\u0006\u001a\u0005\u0008\u00b0\u0001\u0010\u0008R \u0010\u00b1\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00b1\u0001\u0010\u0006\u001a\u0005\u0008\u00b2\u0001\u0010\u0008R \u0010\u00b3\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00b3\u0001\u0010\u0006\u001a\u0005\u0008\u00b4\u0001\u0010\u0008R \u0010\u00b5\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00b5\u0001\u0010\u0006\u001a\u0005\u0008\u00b6\u0001\u0010\u0008R \u0010\u00b7\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00b7\u0001\u0010\u0006\u001a\u0005\u0008\u00b8\u0001\u0010\u0008R \u0010\u00b9\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00b9\u0001\u0010\u0006\u001a\u0005\u0008\u00ba\u0001\u0010\u0008R \u0010\u00bb\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00bb\u0001\u0010\u0006\u001a\u0005\u0008\u00bc\u0001\u0010\u0008R \u0010\u00bd\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00bd\u0001\u0010\u0006\u001a\u0005\u0008\u00be\u0001\u0010\u0008R \u0010\u00bf\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00bf\u0001\u0010\u0006\u001a\u0005\u0008\u00c0\u0001\u0010\u0008R \u0010\u00c1\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00c1\u0001\u0010\u0006\u001a\u0005\u0008\u00c2\u0001\u0010\u0008R \u0010\u00c3\u0001\u001a\u00020\u00048\u0006\u00f8\u0001\u0000\u00f8\u0001\u0001\u00a2\u0006\u000e\n\u0005\u0008\u00c3\u0001\u0010\u0006\u001a\u0005\u0008\u00c4\u0001\u0010\u0008R \u0010\u00c5\u0001\u001a\u0002